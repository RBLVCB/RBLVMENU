function RBLVLibrary:Notification(opts)
    opts = opts or {}
    local title    = opts.Title    or "RBLV"
    local content  = opts.Content  or ""
    local duration = opts.Duration or 4

    local card = New("Frame", {
        Parent           = NotifHolder,
        BackgroundColor3 = Theme.NotifBG,
        Size             = UDim2.new(1, 0, 0, 62),
        ClipsDescendants = false,
    })
    Corner(8, card)
    Stroke(Theme.NotifBorder, 1, card)

    -- Left accent bar
    local bar = New("Frame", {
        Parent           = card,
        BackgroundColor3 = Theme.NotifAccent,
        Position         = UDim2.new(0, 0, 0, 8),
        Size             = UDim2.new(0, 2, 1, -16),
    })
    Corner(2, bar)

    -- Title
    New("TextLabel", {
        Parent               = card,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 14, 0, 10),
        Size                 = UDim2.new(1, -18, 0, 16),
        Text                 = title,
        TextColor3           = Theme.NotifTitle,
        Font                 = Theme.Font,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })

    -- Content
    New("TextLabel", {
        Parent               = card,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 14, 0, 28),
        Size                 = UDim2.new(1, -18, 0, 24),
        Text                 = content,
        TextColor3           = Theme.NotifText,
        Font                 = Theme.FontLight,
        TextSize             = 11,
        TextXAlignment       = Enum.TextXAlignment.Left,
        TextWrapped          = true,
    })

    -- Slide in from right
    card.Position = UDim2.new(1, 300, 0, 0)
    Tween(card, {Position = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    task.delay(duration, function()
        Tween(card, {Position = UDim2.new(1, 300, 0, 0)}, 0.22)
        task.wait(0.25)
        card:Destroy()
    end)
end

