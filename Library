    local TabPages    = {}
    local TabButtons  = {}
    local ActiveTab   = nil

    local function SelectTab(name)
        for n, page in pairs(TabPages) do
            page.Visible = (n == name)
        end
        for n, btn in pairs(TabButtons) do
            local isActive = (n == name)
            Tween(btn,           {BackgroundColor3 = isActive and Theme.TabActive or Theme.TabNormal}, 0.15)
            Tween(btn.TabLabel,  {TextColor3       = isActive and Theme.TabTextActive or Theme.TabTextNormal}, 0.15)
            btn.Accent.Visible = isActive
        end
        ActiveTab = name
    end

    -- ── Tab Builder ──
    function WindowObj:Tab(name)
        -- Sidebar button
        local TabBtn = New("TextButton", {
            Name             = "TabBtn_" .. name,
            Parent           = TabList,
            BackgroundColor3 = Theme.TabNormal,
            Size             = UDim2.new(1, 0, 0, 34),
            Text             = "",
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
        })

        -- Active accent bar
        local Accent = New("Frame", {
            Name             = "Accent",
            Parent           = TabBtn,
            BackgroundColor3 = Theme.TabAccent,
            Position         = UDim2.new(0, 0, 0, 6),
            Size             = UDim2.new(0, 3, 1, -12),
            Visible          = false,
        })
        Corner(2, Accent)

        New("TextLabel", {
            Name             = "TabLabel",
            Parent           = TabBtn,
            BackgroundTransparency = 1,
            Position         = UDim2.new(0, 14, 0, 0),
            Size             = UDim2.new(1, -14, 1, 0),
            Text             = name,
            TextColor3       = Theme.TabTextNormal,
            Font             = Theme.Font,
            TextSize         = 12,
            TextXAlignment   = Enum.TextXAlignment.Left,
        })

        TabBtn.MouseEnter:Connect(function()
            if ActiveTab ~= name then
                Tween(TabBtn, {BackgroundColor3 = Theme.TabHover}, 0.1)
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if ActiveTab ~= name then
                Tween(TabBtn, {BackgroundColor3 = Theme.TabNormal}, 0.1)
            end
        end)

        -- Content page
        local Page = New("ScrollingFrame", {
            Name                   = "Page_" .. name,
            Parent                 = ContentArea,
            BackgroundTransparency = 1,
            Position               = UDim2.new(0, 0, 0, 0),
            Size                   = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness     = 3,
            ScrollBarImageColor3   = Theme.AccentDim,
            CanvasSize             = UDim2.new(0, 0, 0, 0),
            Visible                = false,
            BorderSizePixel        = 0,
        })
        Padding(8, 8, 10, 10, Page)

        local PageList = Instance.new("UIListLayout")
        PageList.Padding          = UDim.new(0, 6)
        PageList.SortOrder        = Enum.SortOrder.LayoutOrder
        PageList.HorizontalAlignment = Enum.HorizontalAlignment.Center
        PageList.Parent           = Page

        PageList.Changed:Connect(function()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageList.AbsoluteContentSize.Y + 20)
        end)

        TabPages[name]   = Page
        TabButtons[name] = TabBtn

        TabBtn.MouseButton1Click:Connect(function()
            SelectTab(name)
        end)

