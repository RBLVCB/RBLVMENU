            local row = New("Frame", {
                Parent           = Page,
                BackgroundTransparency = 1,
                Size             = UDim2.new(1, -20, 0, 52),
                LayoutOrder      = NextOrder(),
            })

            New("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 2, 0, 0),
                Size                 = UDim2.new(1, 0, 0, 18),
                Text                 = text,
                TextColor3           = Theme.SubText,
                Font                 = Theme.Font,
                TextSize             = 11,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local box = New("TextBox", {
                Parent               = row,
                BackgroundColor3     = Theme.TextboxBG,
                Position             = UDim2.new(0, 0, 0, 20),
                Size                 = UDim2.new(1, 0, 0, 30),
                PlaceholderText      = placeholder or "",
                PlaceholderColor3    = Theme.SubText,
                Text                 = "",
                TextColor3           = Theme.TextboxText,
                Font                 = Theme.FontLight,
                TextSize             = 13,
                ClearTextOnFocus     = false,
                BorderSizePixel      = 0,
            })
            Corner(6, box)
            Padding(0, 0, 10, 10, box)

            local stroke = Stroke(Theme.TextboxBorder, 1, box)

            box.Focused:Connect(function()
                Tween(stroke, {Color = Theme.TextboxFocus}, 0.15)
            end)
            box.FocusLost:Connect(function(enter)
                Tween(stroke, {Color = Theme.TextboxBorder}, 0.15)
                if enter then callback(box.Text) end
            end)
        end

        -- ── SLIDER ──
        function TabObj:Slider(text, min, max, default, callback)
            min     = min     or 0
            max     = max     or 100
            default = default or min
            local value = default

            local row = New("Frame", {
                Parent           = Page,
                BackgroundTransparency = 1,
                Size             = UDim2.new(1, -20, 0, 52),
                LayoutOrder      = NextOrder(),
            })

            local header = New("Frame", {
                Parent               = row,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, 0, 0, 18),
            })

            New("TextLabel", {
                Parent               = header,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(0.7, 0, 1, 0),
                Text                 = text,
                TextColor3           = Theme.SubText,
                Font                 = Theme.Font,
                TextSize             = 11,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local valLabel = New("TextLabel", {
                Parent               = header,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0.7, 0, 0, 0),
                Size                 = UDim2.new(0.3, 0, 1, 0),
                Text                 = tostring(default),
                TextColor3           = Theme.Accent,
                Font                 = Theme.Font,
                TextSize             = 11,
                TextXAlignment       = Enum.TextXAlignment.Right,
            })

            local track = New("Frame", {
                Parent           = row,
                BackgroundColor3 = Theme.SliderBG,
                Position         = UDim2.new(0, 0, 0, 22),
                Size             = UDim2.new(1, 0, 0, 16),
            })
            Corner(8, track)
            Stroke(Theme.ElementBorder, 1, track)

            local pct  = (value - min) / (max - min)
            local fill = New("Frame", {
                Parent           = track,
                BackgroundColor3 = Theme.SliderFill,
                Size             = UDim2.new(pct, 0, 1, 0),
                ClipsDescendants = true,
            })
            Corner(8, fill)

            local knob = New("Frame", {
                Parent           = track,
                BackgroundColor3 = Theme.SliderKnob,
                AnchorPoint      = Vector2.new(0.5, 0.5),
                Position         = UDim2.new(pct, 0, 0.5, 0),
                Size             = UDim2.new(0, 12, 0, 12),
                ZIndex           = 2,
            })
            Corner(6, knob)

            local sliding = false
            local function updateSlider(input)
                local trackPos   = track.AbsolutePosition.X
                local trackWidth = track.AbsoluteSize.X
                local rel        = math.clamp((input.Position.X - trackPos) / trackWidth, 0, 1)
                value            = math.floor(min + rel * (max - min))
                valLabel.Text    = tostring(value)
                Tween(fill,  {Size     = UDim2.new(rel, 0, 1, 0)},          0.08)
                Tween(knob,  {Position = UDim2.new(rel, 0, 0.5, 0)},        0.08)
                Tween(fill,  {BackgroundColor3 = Theme.SliderFill},          0.08)
                callback(value)
            end

            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = true
                    updateSlider(input)
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch) then
                    updateSlider(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                end
            end)

            local obj = {}
            function obj:Set(val)
                value = math.clamp(val, min, max)
                local r = (value - min) / (max - min)
                valLabel.Text = tostring(value)
                Tween(fill, {Size     = UDim2.new(r, 0, 1, 0)}, 0.12)
                Tween(knob, {Position = UDim2.new(r, 0, 0.5, 0)}, 0.12)
                callback(value)
            end
            return obj
        end

        -- ── DROPDOWN ──
        function TabObj:Dropdown(text, options, callback)
            local selected = options[1]
            local open     = false

            local wrapper = New("Frame", {
                Parent               = Page,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, -20, 0, 52),
                LayoutOrder          = NextOrder(),
                ClipsDescendants     = false,
                ZIndex               = 3,
            })

            New("TextLabel", {
                Parent               = wrapper,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 2, 0, 0),
                Size                 = UDim2.new(1, 0, 0, 18),
                Text                 = text,
                TextColor3           = Theme.SubText,
                Font                 = Theme.Font,
                TextSize             = 11,
                TextXAlignment       = Enum.TextXAlignment.Left,
                ZIndex               = 3,
            })

            local header = New("TextButton", {
                Parent           = wrapper,
                BackgroundColor3 = Theme.DropdownBG,
                Position         = UDim2.new(0, 0, 0, 20),
                Size             = UDim2.new(1, 0, 0, 30),
                Text             = "",
                AutoButtonColor  = false,
                ZIndex           = 3,
                BorderSizePixel  = 0,
            })
            Corner(6, header)
            Stroke(Theme.DropdownBorder, 1, header)

            local selLabel = New("TextLabel", {
                Parent               = header,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 10, 0, 0),
                Size                 = UDim2.new(1, -30, 1, 0),
                Text                 = selected,
                TextColor3           = Theme.DropdownText,
                Font                 = Theme.FontLight,
                TextSize             = 13,
                TextXAlignment       = Enum.TextXAlignment.Left,
                ZIndex               = 4,
            })

            New("TextLabel", {
                Parent               = header,
                BackgroundTransparency = 1,
                Position             = UDim2.new(1, -24, 0, 0),
                Size                 = UDim2.new(0, 20, 1, 0),
                Text                 = "▾",
                TextColor3           = Theme.AccentDim,
                Font                 = Theme.Font,
                TextSize             = 13,
                ZIndex               = 4,
            })

            -- Dropdown list
            local listFrame = New("Frame", {
                Parent           = wrapper,
                BackgroundColor3 = Theme.DropdownOpen,
                Position         = UDim2.new(0, 0, 0, 52),
                Size             = UDim2.new(1, 0, 0, 0),
                ClipsDescendants = true,
                Visible          = false,
                ZIndex           = 10,
            })
            Corner(6, listFrame)
            Stroke(Theme.DropdownBorder, 1, listFrame)

            local itemList = Instance.new("UIListLayout")
            itemList.SortOrder = Enum.SortOrder.LayoutOrder
            itemList.Parent    = listFrame

            for i, opt in ipairs(options) do
                local item = New("TextButton", {
                    Parent           = listFrame,
                    BackgroundColor3 = Theme.DropdownItem,
                    Size             = UDim2.new(1, 0, 0, 28),
                    Text             = "",
                    AutoButtonColor  = false,
                    LayoutOrder      = i,
                    ZIndex           = 11,
                    BorderSizePixel  = 0,
                })

                New("TextLabel", {
                    Parent               = item,
                    BackgroundTransparency = 1,
                    Position             = UDim2.new(0, 10, 0, 0),
                    Size                 = UDim2.new(1, -10, 1, 0),
                    Text                 = opt,
                    TextColor3           = Theme.DropdownText,
                    Font                 = Theme.FontLight,
                    TextSize             = 13,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                    ZIndex               = 12,
                })

                item.MouseEnter:Connect(function()
                    Tween(item, {BackgroundColor3 = Theme.DropdownHover}, 0.1)
                end)
                item.MouseLeave:Connect(function()
                    Tween(item, {BackgroundColor3 = Theme.DropdownItem}, 0.1)
                end)
                item.MouseButton1Click:Connect(function()
                    selected      = opt
                    selLabel.Text = opt
                    open          = false
                    listFrame.Visible = false
                    wrapper.Size  = UDim2.new(1, -20, 0, 52)
                    callback(opt)
                end)
            end

            local listHeight = #options * 28 + 4

            header.MouseButton1Click:Connect(function()
                open = not open
                listFrame.Visible = open
                if open then
                    wrapper.Size      = UDim2.new(1, -20, 0, 52 + listHeight + 4)
                    listFrame.Size    = UDim2.new(1, 0, 0, listHeight)
                else
                    wrapper.Size      = UDim2.new(1, -20, 0, 52)
                    listFrame.Size    = UDim2.new(1, 0, 0, 0)
                end
            end)
        end

        -- ── KEYBIND ──
        function TabObj:Keybind(text, default, callback)
            local key     = default or Enum.KeyCode.RightShift
            local binding = false

            local row = New("Frame", {
                Parent           = Page,
                BackgroundColor3 = Theme.ElementBG,
                Size             = UDim2.new(1, -20, 0, 36),
                LayoutOrder      = NextOrder(),
            })
            Corner(6, row)
            Stroke(Theme.ElementBorder, 1, row)

            New("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 12, 0, 0),
                Size                 = UDim2.new(1, -90, 1, 0),
                Text                 = text,
                TextColor3           = Theme.LabelText,
                Font                 = Theme.FontLight,
                TextSize             = 13,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local keyBtn = New("TextButton", {
                Parent           = row,
                BackgroundColor3 = Theme.KeybindBG,
                Position         = UDim2.new(1, -76, 0.5, -12),
                Size             = UDim2.new(0, 64, 0, 24),
                Text             = tostring(key.Name),
                TextColor3       = Theme.KeybindText,
                Font             = Theme.Font,
                TextSize         = 11,
                AutoButtonColor  = false,
                BorderSizePixel  = 0,
            })
            Corner(5, keyBtn)
            Stroke(Theme.KeybindBorder, 1, keyBtn)

            keyBtn.MouseButton1Click:Connect(function()
                binding       = true
                keyBtn.Text   = "..."
                Tween(keyBtn, {BackgroundColor3 = Theme.KeybindActive}, 0.15)
            end)

            UserInputService.InputBegan:Connect(function(input, processed)
                if binding and not processed then
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        key           = input.KeyCode
                        binding       = false
                        keyBtn.Text   = key.Name
                        Tween(keyBtn, {BackgroundColor3 = Theme.KeybindBG}, 0.15)
                    end
                elseif not binding and input.UserInputType == Enum.UserInputType.Keyboard then
                    if input.KeyCode == key then
                        callback(key)
                    end
                end
            end)

            local obj = {}
            function obj:Set(newKey)
                key           = newKey
                keyBtn.Text   = key.Name
            end
            return obj
        end

