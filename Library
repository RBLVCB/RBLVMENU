    TabBarLayout.Padding              = UDim.new(0, 2)
    TabBarLayout.SortOrder            = Enum.SortOrder.LayoutOrder
    TabBarLayout.Parent               = TabScroll

    TabBarLayout.Changed:Connect(function()
        TabScroll.CanvasSize = UDim2.new(0, TabBarLayout.AbsoluteContentSize.X + 16, 0, 0)
    end)

    -- ── Content Area ──
    local ContentArea = New("Frame", {
        Name             = "ContentArea",
        Parent           = MainFrame,
        BackgroundColor3 = Theme.ContentBG,
        Position         = UDim2.new(0, 0, 0, 70),
        Size             = UDim2.new(1, 0, 1, -70),
        ClipsDescendants = true,
    })

    -- ── Window Object ──
    local WindowObj  = {}
    local TabPages   = {}
    local TabBtns    = {}
    local ActiveTab  = nil
    local TabCount   = 0

    local function SelectTab(name)
        for n, page in pairs(TabPages) do
            page.Visible = (n == name)
        end
        for n, btn in pairs(TabBtns) do
            local active = (n == name)
            Tween(btn.Label,     {TextColor3 = active and Theme.TabTextActive or Theme.TabTextNormal}, 0.15)
            Tween(btn.Underline, {BackgroundTransparency = active and 0 or 1}, 0.15)
            btn.BackgroundColor3 = active and Theme.TabActive or Theme.TabNormal
        end
        ActiveTab = name
    end

    -- ── Tab Builder ──
    function WindowObj:Tab(name)
        TabCount = TabCount + 1

        -- Measure text width roughly (7px per char + padding)
        local btnW = math.max(60, #name * 7 + 22)

        local TabBtn = New("TextButton", {
            Name             = "Tab_" .. name,
            Parent           = TabScroll,
            BackgroundColor3 = Theme.TabNormal,
            Size             = UDim2.new(0, btnW, 1, 0),
            Text             = "",
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
            ZIndex           = 5,
            LayoutOrder      = TabCount,
        })

        -- Tab label
        local TabLabel = New("TextLabel", {
            Name                 = "Label",
            Parent               = TabBtn,
            BackgroundTransparency = 1,
            Size                 = UDim2.new(1, 0, 1, -3),
            Text                 = name,
            TextColor3           = Theme.TabTextNormal,
            Font                 = Theme.Font,
            TextSize             = 11,
            TextXAlignment       = Enum.TextXAlignment.Center,
            ZIndex               = 6,
        })

        -- Underline indicator (like NeonHub active tab)
        local Underline = New("Frame", {
            Name             = "Underline",
            Parent           = TabBtn,
            BackgroundColor3 = Theme.TabUnderline,
            BackgroundTransparency = 1,
            Position         = UDim2.new(0, 4, 1, -2),
            Size             = UDim2.new(1, -8, 0, 2),
            ZIndex           = 6,
        })
        Corner(1, Underline)

        TabBtn.Label     = TabLabel
        TabBtn.Underline = Underline

        TabBtn.MouseEnter:Connect(function()
            if ActiveTab ~= name then
                Tween(TabBtn, {BackgroundColor3 = Theme.TabHover}, 0.1)
                Tween(TabLabel, {TextColor3 = Color3.fromRGB(120, 145, 210)}, 0.1)
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if ActiveTab ~= name then
                Tween(TabBtn, {BackgroundColor3 = Theme.TabNormal}, 0.1)
                Tween(TabLabel, {TextColor3 = Theme.TabTextNormal}, 0.1)
            end
        end)
        TabBtn.MouseButton1Click:Connect(function()
            SelectTab(name)
        end)

        -- ── Page ──
        local Page = New("ScrollingFrame", {
            Name                 = "Page_" .. name,
            Parent               = ContentArea,
            BackgroundTransparency = 1,
            Position             = UDim2.new(0, 0, 0, 0),
            Size                 = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness   = 3,
            ScrollBarImageColor3 = Theme.ScrollBar,
            CanvasSize           = UDim2.new(0, 0, 0, 0),
            Visible              = false,
            BorderSizePixel      = 0,
        })
        Pad(8, 8, 10, 10, Page)

        local PageLayout = Instance.new("UIListLayout")
        PageLayout.Padding              = UDim.new(0, 5)
        PageLayout.SortOrder            = Enum.SortOrder.LayoutOrder
        PageLayout.HorizontalAlignment  = Enum.HorizontalAlignment.Center
        PageLayout.Parent               = Page

        PageLayout.Changed:Connect(function()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 18)
        end)

        TabPages[name] = Page
        TabBtns[name]  = TabBtn

        if not ActiveTab then SelectTab(name) end

        -- ── Element Builder ──
        local TabObj  = {}
        local EOrder  = 0
        local function NO() EOrder = EOrder + 1; return EOrder end

        -- ── LABEL ──
        function TabObj:Label(text)
            local row = New("Frame", {
                Parent               = Page,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, -20, 0, 22),
                LayoutOrder          = NO(),
            })

            New("Frame", {
                Parent           = row,
                BackgroundColor3 = Theme.SectionLine,
                AnchorPoint      = Vector2.new(0, 0.5),
                Position         = UDim2.new(0, 0, 0.5, 0),
                Size             = UDim2.new(1, 0, 0, 1),
            })

            local lbl = New("TextLabel", {
                Parent               = row,
                BackgroundColor3     = Theme.ContentBG,
                BackgroundTransparency = 0,
                AnchorPoint          = Vector2.new(0.5, 0.5),
                Position             = UDim2.new(0.5, 0, 0.5, 0),
                Size                 = UDim2.new(0, #text * 6 + 16, 0, 14),
                Text                 = text,
                TextColor3           = Theme.SectionText,
                Font                 = Theme.Font,
                TextSize             = 10,
                TextXAlignment       = Enum.TextXAlignment.Center,
            })

            return row
        end

        -- ── TOGGLE ──
        function TabObj:Toggle(text, default, callback)
            local state = default or false

            local row = New("Frame", {
                Parent           = Page,
                BackgroundColor3 = Theme.ElementBG,
                Size             = UDim2.new(1, -20, 0, 34),
                LayoutOrder      = NO(),
            })
            Corner(6, row)
            Stroke(Theme.ElementBorder, 1, row)

            New("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 10, 0, 0),
                Size                 = UDim2.new(1, -58, 1, 0),
                Text                 = text,
                TextColor3           = Theme.LabelText,
                Font                 = Theme.FontLight,
                TextSize             = 12,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local track = New("Frame", {
                Parent           = row,
                BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff,
                Position         = UDim2.new(1, -44, 0.5, -9),
                Size             = UDim2.new(0, 32, 0, 18),
            })
            Corner(9, track)

            local knob = New("Frame", {
                Parent           = track,
                BackgroundColor3 = Theme.ToggleKnob,
                Position         = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6),
                Size             = UDim2.new(0, 12, 0, 12),
            })
            Corner(6, knob)

            local hitbox = New("TextButton", {
                Parent               = row,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, 0, 1, 0),
                Text                 = "",
                ZIndex               = 2,
                AutoButtonColor      = false,
            })

            hitbox.MouseButton1Click:Connect(function()
                state = not state
                Tween(track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.18)
                Tween(knob,  {Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)}, 0.18)
                callback(state)
            end)
            hitbox.MouseEnter:Connect(function()
                Tween(row, {BackgroundColor3 = Theme.ElementHover}, 0.1)
            end)
            hitbox.MouseLeave:Connect(function()
                Tween(row, {BackgroundColor3 = Theme.ElementBG}, 0.1)
            end)

            local obj = {}
            function obj:Set(val)
                state = val
                Tween(track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.18)
                Tween(knob,  {Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)}, 0.18)
                callback(state)
            end
            return obj
        end

        -- ── BUTTON ──
        function TabObj:Button(text, callback)
            local btn = New("TextButton", {
                Parent           = Page,
                BackgroundColor3 = Theme.ButtonBG,
                Size             = UDim2.new(1, -20, 0, 32),
                Text             = text,
                TextColor3       = Theme.ButtonText,
                Font             = Theme.Font,
                TextSize         = 12,
                AutoButtonColor  = false,
                LayoutOrder      = NO(),
                BorderSizePixel  = 0,
            })
            Corner(6, btn)
            Stroke(Theme.ButtonBorder, 1, btn)

            btn.MouseEnter:Connect(function()
                Tween(btn, {BackgroundColor3 = Theme.ButtonHover}, 0.1)
            end)
            btn.MouseLeave:Connect(function()
                Tween(btn, {BackgroundColor3 = Theme.ButtonBG}, 0.1)
            end)
            btn.MouseButton1Down:Connect(function()
                Tween(btn, {Size = UDim2.new(1, -24, 0, 30)}, 0.07)
            end)
            btn.MouseButton1Up:Connect(function()
                Tween(btn, {Size = UDim2.new(1, -20, 0, 32)}, 0.1)
            end)
            btn.MouseButton1Click:Connect(callback)
        end

        -- ── TEXTBOX ──
        function TabObj:Textbox(text, placeholder, callback)
            local row = New("Frame", {
                Parent               = Page,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, -20, 0, 50),
                LayoutOrder          = NO(),
            })

            New("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 2, 0, 0),
                Size                 = UDim2.new(1, 0, 0, 16),
                Text                 = text,
                TextColor3           = Theme.SubText,
                Font                 = Theme.Font,
                TextSize             = 10,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local box = New("TextBox", {
                Parent               = row,
                BackgroundColor3     = Theme.TextboxBG,
                Position             = UDim2.new(0, 0, 0, 18),
                Size                 = UDim2.new(1, 0, 0, 28),
                PlaceholderText      = placeholder or "",
                PlaceholderColor3    = Theme.PlaceholderText,
                Text                 = "",
                TextColor3           = Theme.TextboxText,
                Font                 = Theme.FontLight,
                TextSize             = 12,
                ClearTextOnFocus     = false,
                BorderSizePixel      = 0,
            })
            Corner(6, box)
            Pad(0, 0, 10, 10, box)

            local stroke = Stroke(Theme.TextboxBorder, 1, box)

            box.Focused:Connect(function()
                Tween(stroke, {Color = Theme.TextboxFocus}, 0.15)
            end)
            box.FocusLost:Connect(function(enter)
                Tween(stroke, {Color = Theme.TextboxBorder}, 0.15)
                if enter then callback(box.Text) end
            end)
        end

        -- ── SLIDER ──
        function TabObj:Slider(text, min, max, default, callback)
            min     = min     or 0
            max     = max     or 100
            default = math.clamp(default or min, min, max)
            local value = default

            local row = New("Frame", {
                Parent               = Page,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, -20, 0, 50),
                LayoutOrder          = NO(),
            })

            -- Header row
            New("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 2, 0, 0),
                Size                 = UDim2.new(0.65, 0, 0, 16),
                Text                 = text,
                TextColor3           = Theme.SubText,
                Font                 = Theme.Font,
                TextSize             = 10,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local valLbl = New("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0.65, 0, 0, 0),
                Size                 = UDim2.new(0.35, -2, 0, 16),
                Text                 = tostring(value),
                TextColor3           = Theme.Accent,
                Font                 = Theme.Font,
                TextSize             = 10,
                TextXAlignment       = Enum.TextXAlignment.Right,
            })

            -- Track
            local track = New("Frame", {
                Parent           = row,
                BackgroundColor3 = Theme.SliderTrack,
                Position         = UDim2.new(0, 0, 0, 20),
                Size             = UDim2.new(1, 0, 0, 14),
            })
            Corner(7, track)
            Stroke(Theme.ElementBorder, 1, track)

            local pct  = (value - min) / (max - min)

            local fill = New("Frame", {
                Parent           = track,
                BackgroundColor3 = Theme.SliderFill,
                Size             = UDim2.new(pct, 0, 1, 0),
            })
            Corner(7, fill)

            local knob = New("Frame", {
                Parent           = track,
                BackgroundColor3 = Theme.SliderKnob,
                AnchorPoint      = Vector2.new(0.5, 0.5),
                Position         = UDim2.new(pct, 0, 0.5, 0),
                Size             = UDim2.new(0, 10, 0, 10),
                ZIndex           = 2,
            })
            Corner(5, knob)

            local sliding = false
            local function update(input)
                local rel = math.clamp(
                    (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X,
                    0, 1
                )
                value        = math.floor(min + rel * (max - min))
                valLbl.Text  = tostring(value)
                Tween(fill,  {Size     = UDim2.new(rel, 0, 1, 0)},   0.07)
                Tween(knob,  {Position = UDim2.new(rel, 0, 0.5, 0)}, 0.07)
                callback(value)
            end

            track.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    sliding = true; update(inp)
                end
            end)
            UserInputService.InputChanged:Connect(function(inp)
                if sliding and (inp.UserInputType == Enum.UserInputType.MouseMovement
                    or inp.UserInputType == Enum.UserInputType.Touch) then
                    update(inp)
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                end
            end)

            local obj = {}
            function obj:Set(val)
                value = math.clamp(val, min, max)
                local r = (value - min) / (max - min)
                valLbl.Text = tostring(value)
                Tween(fill, {Size     = UDim2.new(r, 0, 1, 0)},   0.12)
                Tween(knob, {Position = UDim2.new(r, 0, 0.5, 0)}, 0.12)
                callback(value)
            end
            return obj
        end

        -- ── DROPDOWN ──
        function TabObj:Dropdown(text, options, callback)
            local selected = options[1] or "-- None --"
            local open     = false

            local wrapper = New("Frame", {
                Parent               = Page,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, -20, 0, 50),
                LayoutOrder          = NO(),
                ClipsDescendants     = false,
                ZIndex               = 3,
            })

            New("TextLabel", {
                Parent               = wrapper,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 2, 0, 0),
                Size                 = UDim2.new(1, 0, 0, 16),
                Text                 = text,
                TextColor3           = Theme.SubText,
                Font                 = Theme.Font,
                TextSize             = 10,
                TextXAlignment       = Enum.TextXAlignment.Left,
                ZIndex               = 3,
            })

            local header = New("TextButton", {
                Parent           = wrapper,
                BackgroundColor3 = Theme.DropdownBG,
                Position         = UDim2.new(0, 0, 0, 18),
                Size             = UDim2.new(1, 0, 0, 28),
                Text             = "",
                AutoButtonColor  = false,
                ZIndex           = 4,
                BorderSizePixel  = 0,
            })
            Corner(6, header)
            Stroke(Theme.DropdownBorder, 1, header)

            local selLbl = New("TextLabel", {
                Parent               = header,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 10, 0, 0),
                Size                 = UDim2.new(1, -28, 1, 0),
                Text                 = selected,
                TextColor3           = Theme.DropdownText,
                Font                 = Theme.FontLight,
                TextSize             = 12,
                TextXAlignment       = Enum.TextXAlignment.Left,
                ZIndex               = 5,
            })

            New("TextLabel", {
                Parent               = header,
                BackgroundTransparency = 1,
                Position             = UDim2.new(1, -22, 0, 0),
                Size                 = UDim2.new(0, 18, 1, 0),
                Text                 = "▾",
                TextColor3           = Theme.DropdownArrow,
                Font                 = Theme.Font,
                TextSize             = 12,
                ZIndex               = 5,
            })

            -- The list (floats below)
            local itemH    = 26
            local listH    = math.min(#options, 8) * itemH + 4
            local listFrame = New("Frame", {
                Parent           = wrapper,
                BackgroundColor3 = Theme.DropdownOpen,
                Position         = UDim2.new(0, 0, 0, 50),
                Size             = UDim2.new(1, 0, 0, 0),
                ClipsDescendants = true,
                Visible          = false,
                ZIndex           = 20,
            })
            Corner(6, listFrame)
            Stroke(Theme.DropdownBorder, 1, listFrame)

            local listScroll = New("ScrollingFrame", {
                Parent               = listFrame,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, 0, 1, 0),
                ScrollBarThickness   = 2,
                ScrollBarImageColor3 = Theme.ScrollBar,
                CanvasSize           = UDim2.new(0, 0, 0, #options * itemH + 4),
                BorderSizePixel      = 0,
                ZIndex               = 21,
            })

            local itemLayout = Instance.new("UIListLayout")
            itemLayout.SortOrder = Enum.SortOrder.LayoutOrder
            itemLayout.Padding   = UDim.new(0, 2)
            itemLayout.Parent    = listScroll

            Pad(2, 2, 2, 2, listScroll)

            for i, opt in ipairs(options) do
                local item = New("TextButton", {
                    Parent           = listScroll,
                    BackgroundColor3 = Theme.DropdownItem,
                    Size             = UDim2.new(1, -4, 0, itemH - 2),
                    Text             = "",
                    AutoButtonColor  = false,
                    LayoutOrder      = i,
                    ZIndex           = 22,
                    BorderSizePixel  = 0,
                })
                Corner(4, item)

                New("TextLabel", {
                    Parent               = item,
                    BackgroundTransparency = 1,
                    Position             = UDim2.new(0, 8, 0, 0),
                    Size                 = UDim2.new(1, -8, 1, 0),
                    Text                 = opt,
                    TextColor3           = Theme.DropdownText,
                    Font                 = Theme.FontLight,
                    TextSize             = 12,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                    ZIndex               = 23,
                })

                item.MouseEnter:Connect(function()
                    Tween(item, {BackgroundColor3 = Theme.DropdownHover}, 0.1)
                end)
                item.MouseLeave:Connect(function()
                    Tween(item, {BackgroundColor3 = Theme.DropdownItem}, 0.1)
                end)
                item.MouseButton1Click:Connect(function()
                    selected      = opt
                    selLbl.Text   = opt
                    open          = false
                    listFrame.Visible = false
                    wrapper.Size  = UDim2.new(1, -20, 0, 50)
                    callback(opt)
                end)
            end

            header.MouseButton1Click:Connect(function()
                open = not open
                listFrame.Visible = open
                if open then
                    wrapper.Size   = UDim2.new(1, -20, 0, 50 + listH + 4)
                    Tween(listFrame, {Size = UDim2.new(1, 0, 0, listH)}, 0.15)
                else
                    Tween(listFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.12)
                    wrapper.Size   = UDim2.new(1, -20, 0, 50)
                end
            end)
        end

        -- ── KEYBIND ──
        function TabObj:Keybind(text, default, callback)
            local key     = default or Enum.KeyCode.RightShift
            local binding = false

            local row = New("Frame", {
                Parent           = Page,
                BackgroundColor3 = Theme.ElementBG,
                Size             = UDim2.new(1, -20, 0, 34),
                LayoutOrder      = NO(),
            })
            Corner(6, row)
            Stroke(Theme.ElementBorder, 1, row)

            New("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 10, 0, 0),
                Size                 = UDim2.new(1, -86, 1, 0),
                Text                 = text,
                TextColor3           = Theme.LabelText,
                Font                 = Theme.FontLight,
                TextSize             = 12,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local keyBtn = New("TextButton", {
                Parent           = row,
                BackgroundColor3 = Theme.KeybindBG,
                Position         = UDim2.new(1, -74, 0.5, -11),
                Size             = UDim2.new(0, 62, 0, 22),
                Text             = key.Name,
                TextColor3       = Theme.KeybindText,
                Font             = Theme.Font,
                TextSize         = 10,
                AutoButtonColor  = false,
                BorderSizePixel  = 0,
            })
            Corner(5, keyBtn)
            Stroke(Theme.KeybindBorder, 1, keyBtn)

            keyBtn.MouseButton1Click:Connect(function()
                binding       = true
                keyBtn.Text   = "..."
                Tween(keyBtn, {BackgroundColor3 = Theme.KeybindActive}, 0.15)
            end)

            UserInputService.InputBegan:Connect(function(input, gpe)
                if binding and not gpe then
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        key           = input.KeyCode
                        binding       = false
                        keyBtn.Text   = key.Name
                        Tween(keyBtn, {BackgroundColor3 = Theme.KeybindBG}, 0.15)
                    end
                elseif not binding and input.UserInputType == Enum.UserInputType.Keyboard then
                    if input.KeyCode == key then callback(key) end
                end
            end)

            local obj = {}
            function obj:Set(k) key = k; keyBtn.Text = k.Name end
            return obj
        end

        function WindowObj:AddConfig() end

        return TabObj
    end

    -- Open animation
    MainFrame.Size = UDim2.new(0, 560, 0, 0)
    Tween(MainFrame, {Size = fullSize}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    return WindowObj
end

return RBLVLibrary
