            local row = New("Frame", {
                Parent               = Page,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, -20, 0, 24),
                LayoutOrder          = NextOrder(),
            })

            New("Frame", {
                Parent           = row,
                BackgroundColor3 = Theme.SectionLine,
                Position         = UDim2.new(0, 0, 0.5, 0),
                Size             = UDim2.new(1, 0, 0, 1),
            })

            New("TextLabel", {
                Parent               = row,
                BackgroundColor3     = Theme.ContentBG,
                BackgroundTransparency = 0,
                Position             = UDim2.new(0.5, -40, 0, 4),
                Size                 = UDim2.new(0, 80, 0, 16),
                Text                 = text,
                TextColor3           = Theme.SectionText,
                Font                 = Theme.Font,
                TextSize             = 11,
                TextXAlignment       = Enum.TextXAlignment.Center,
            })

            return row
        end

        -- ── TOGGLE ──
        function TabObj:Toggle(text, default, callback)
            local state = default or false

            local row = New("Frame", {
                Parent           = Page,
                BackgroundColor3 = Theme.ElementBG,
                Size             = UDim2.new(1, -20, 0, 36),
                LayoutOrder      = NextOrder(),
            })
            Corner(6, row)
            Stroke(Theme.ElementBorder, 1, row)

            New("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 12, 0, 0),
                Size                 = UDim2.new(1, -60, 1, 0),
                Text                 = text,
                TextColor3           = Theme.LabelText,
                Font                 = Theme.FontLight,
                TextSize             = 13,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local track = New("Frame", {
                Parent           = row,
                BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff,
                Position         = UDim2.new(1, -46, 0.5, -10),
                Size             = UDim2.new(0, 34, 0, 20),
            })
            Corner(10, track)

            local knob = New("Frame", {
                Parent           = track,
                BackgroundColor3 = Theme.ToggleKnob,
                Position         = state and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7),
                Size             = UDim2.new(0, 14, 0, 14),
            })
            Corner(7, knob)

            local btn = New("TextButton", {
                Parent               = row,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, 0, 1, 0),
                Text                 = "",
                ZIndex               = 2,
            })

            btn.MouseButton1Click:Connect(function()
                state = not state
                Tween(track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.18)
                Tween(knob,  {Position = state and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)}, 0.18)
                callback(state)
            end)

            btn.MouseEnter:Connect(function()
                Tween(row, {BackgroundColor3 = Theme.ElementHover}, 0.1)
            end)
            btn.MouseLeave:Connect(function()
                Tween(row, {BackgroundColor3 = Theme.ElementBG}, 0.1)
            end)

            local obj = {}
            function obj:Set(val)
                state = val
                Tween(track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.18)
                Tween(knob,  {Position = state and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)}, 0.18)
                callback(state)
            end
            return obj
        end

        -- ── BUTTON ──
        function TabObj:Button(text, callback)
            local btn = New("TextButton", {
                Parent           = Page,
                BackgroundColor3 = Theme.ButtonBG,
                Size             = UDim2.new(1, -20, 0, 34),
                Text             = text,
                TextColor3       = Theme.ButtonText,
                Font             = Theme.Font,
                TextSize         = 13,
                AutoButtonColor  = false,
                LayoutOrder      = NextOrder(),
                BorderSizePixel  = 0,
