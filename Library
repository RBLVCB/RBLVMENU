            Corner(6, btn)
            Stroke(Theme.ButtonBorder, 1, btn)

            btn.MouseEnter:Connect(function()
                Tween(btn, {BackgroundColor3 = Theme.ButtonHover}, 0.1)
            end)
            btn.MouseLeave:Connect(function()
                Tween(btn, {BackgroundColor3 = Theme.ButtonBG}, 0.1)
            end)
            btn.MouseButton1Down:Connect(function()
                Tween(btn, {Size = UDim2.new(1, -24, 0, 32)}, 0.08)
            end)
            btn.MouseButton1Up:Connect(function()
                Tween(btn, {Size = UDim2.new(1, -20, 0, 34)}, 0.1)
            end)
            btn.MouseButton1Click:Connect(callback)
        end

