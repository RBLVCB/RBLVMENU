    -- Tab buttons go in a horizontal scroll container
    local TabScroll = New("ScrollingFrame", {
        Parent               = TabBar,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 8, 0, 0),
        Size                 = UDim2.new(1, -8, 1, 0),
        ScrollBarThickness   = 0,
