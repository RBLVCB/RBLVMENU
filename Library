        Parent            = card,
        BackgroundTransparency = 1,
        Image             = "rbxassetid://6014261993",
        ImageColor3       = Color3.fromRGB(0, 0, 0),
        ImageTransparency = 0.6,
        Position          = UDim2.new(0, -10, 0, -10),
        Size              = UDim2.new(1, 20, 1, 20),
        ZIndex            = 0,
