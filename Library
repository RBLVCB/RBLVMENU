        Parent           = Body,
        BackgroundColor3 = Theme.ContentBG,
        Position         = UDim2.new(0, 150, 0, 0),
        Size             = UDim2.new(1, -150, 1, 0),
    })

    -- ── Window Object ──
    local WindowObj   = {}
    local TabPages    = {}
    local TabButtons  = {}
    local ActiveTab   = nil

    local function SelectTab(name)
        for n, page in pairs(TabPages) do
            page.Visible = (n == name)
            if n == name then
                page.CanvasPosition = Vector2.new(0,0)
            end
        end
        for n, btn in pairs(TabButtons) do
            local isActive = (n == name)
            Tween(btn,           {BackgroundColor3 = isActive and Theme.TabActive or Theme.TabNormal}, 0.2)
            Tween(btn.TabLabel,  {TextColor3       = isActive and Theme.TabTextActive or Theme.TabTextNormal}, 0.2)
            Tween(btn.Accent,    {BackgroundTransparency = isActive and 0 or 1}, 0.2)
        end
        ActiveTab = name
    end

    function WindowObj:Tab(name)
        -- Sidebar button wrapper to allow padding without scaling issues
        local TabBtnWrapper = New("Frame", {
            Parent = TabList,
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundTransparency = 1
        })
        Padding(0,0,10,10, TabBtnWrapper)

        local TabBtn = New("TextButton", {
            Name             = "TabBtn_" .. name,
            Parent           = TabBtnWrapper,
            BackgroundColor3 = Theme.TabNormal,
            Size             = UDim2.new(1, 0, 1, 0),
            Text             = "",
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
        })
        Corner(6, TabBtn)

        local Accent = New("Frame", {
            Name             = "Accent",
            Parent           = TabBtn,
            BackgroundColor3 = Theme.TabAccent,
            Position         = UDim2.new(0, 4, 0.5, -8),
            Size             = UDim2.new(0, 3, 0, 16),
            BackgroundTransparency = 1,
        })
        Corner(2, Accent)

        New("TextLabel", {
            Name             = "TabLabel",
            Parent           = TabBtn,
            BackgroundTransparency = 1,
            Position         = UDim2.new(0, 16, 0, 0),
            Size             = UDim2.new(1, -16, 1, 0),
            Text             = name,
            TextColor3       = Theme.TabTextNormal,
            Font             = Theme.Font,
            TextSize         = 13,
            TextXAlignment   = Enum.TextXAlignment.Left,
        })

        TabBtn.MouseEnter:Connect(function()
            if ActiveTab ~= name then Tween(TabBtn, {BackgroundColor3 = Theme.TabHover}, 0.15) end
        end)
        TabBtn.MouseLeave:Connect(function()
            if ActiveTab ~= name then Tween(TabBtn, {BackgroundColor3 = Theme.TabNormal}, 0.15) end
        end)

        local Page = New("ScrollingFrame", {
            Name                   = "Page_" .. name,
            Parent                 = ContentArea,
            BackgroundTransparency = 1,
            Position               = UDim2.new(0, 0, 0, 0),
            Size                   = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness     = 4,
            ScrollBarImageColor3   = Theme.AccentDim,
            CanvasSize             = UDim2.new(0, 0, 0, 0),
            Visible                = false,
            BorderSizePixel        = 0,
        })
        Padding(14, 14, 16, 16, Page)

        local PageList = Instance.new("UIListLayout")
        PageList.Padding          = UDim.new(0, 8)
        PageList.SortOrder        = Enum.SortOrder.LayoutOrder
        PageList.HorizontalAlignment = Enum.HorizontalAlignment.Center
        PageList.Parent           = Page

        PageList.Changed:Connect(function()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageList.AbsoluteContentSize.Y + 28)
        end)

        TabPages[name]   = Page
        TabButtons[name] = TabBtn

        TabBtn.MouseButton1Click:Connect(function() SelectTab(name) end)
        if not ActiveTab then SelectTab(name) end

        -- ── Element Builder ──
        local TabObj   = {}
        local ElemOrder = 0
        local function NextOrder() ElemOrder = ElemOrder + 1; return ElemOrder end

        -- ── LABEL ──
        function TabObj:Label(text)
            local row = New("Frame", {
                Parent               = Page,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, -4, 0, 28),
                LayoutOrder          = NextOrder(),
            })

            New("Frame", {
                Parent           = row,
                BackgroundColor3 = Theme.SectionLine,
                Position         = UDim2.new(0, 0, 0.5, 0),
                Size             = UDim2.new(1, 0, 0, 1),
            })

            local txtLabel = New("TextLabel", {
                Parent               = row,
                BackgroundColor3     = Theme.ContentBG,
                BackgroundTransparency = 0,
                Position             = UDim2.new(0.5, -60, 0, 6),
                Size                 = UDim2.new(0, 120, 0, 16),
                Text                 = text,
                TextColor3           = Theme.SectionText,
                Font                 = Theme.Font,
                TextSize             = 12,
                TextXAlignment       = Enum.TextXAlignment.Center,
            })
            -- Adjust background based on text length to hide line properly
            txtLabel.Size = UDim2.new(0, txtLabel.TextBounds.X + 16, 0, 16)
            txtLabel.Position = UDim2.new(0.5, -(txtLabel.Size.X.Offset / 2), 0, 6)
            
            return row
        end

        -- ── TOGGLE ──
        function TabObj:Toggle(text, default, callback)
            local state = default or false

            local row = New("Frame", {
                Parent           = Page,
                BackgroundColor3 = Theme.ElementBG,
                Size             = UDim2.new(1, -4, 0, 42),
                LayoutOrder      = NextOrder(),
            })
            Corner(8, row)
            Stroke(Theme.ElementBorder, 1, row)

            New("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 14, 0, 0),
                Size                 = UDim2.new(1, -60, 1, 0),
                Text                 = text,
                TextColor3           = Theme.LabelText,
                Font                 = Theme.FontMedium,
                TextSize             = 14,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local track = New("Frame", {
                Parent           = row,
                BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff,
                Position         = UDim2.new(1, -48, 0.5, -11),
                Size             = UDim2.new(0, 36, 0, 22),
            })
            Corner(11, track)

            local knob = New("Frame", {
                Parent           = track,
                BackgroundColor3 = Theme.ToggleKnob,
                Position         = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
                Size             = UDim2.new(0, 16, 0, 16),
            })
            Corner(8, knob)

            local btn = New("TextButton", {
                Parent               = row,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, 0, 1, 0),
                Text                 = "",
                ZIndex               = 2,
            })

            local function UpdateToggle()
                Tween(track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.25)
                Tween(knob,  {Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)}, 0.25, Enum.EasingStyle.Back)
            end

            btn.MouseButton1Click:Connect(function()
                state = not state
                UpdateToggle()
                callback(state)
            end)

            btn.MouseEnter:Connect(function() Tween(row, {BackgroundColor3 = Theme.ElementHover}, 0.15) end)
            btn.MouseLeave:Connect(function() Tween(row, {BackgroundColor3 = Theme.ElementBG}, 0.15) end)

            local obj = {}
            function obj:Set(val)
                state = val
                UpdateToggle()
                callback(state)
            end
            return obj
        end

        -- ── BUTTON ──
        function TabObj:Button(text, callback)
            local btn = New("TextButton", {
                Parent           = Page,
                BackgroundColor3 = Theme.ButtonBG,
                Size             = UDim2.new(1, -4, 0, 38),
                Text             = text,
                TextColor3       = Theme.ButtonText,
                Font             = Theme.Font,
                TextSize         = 14,
                AutoButtonColor  = false,
                LayoutOrder      = NextOrder(),
                BorderSizePixel  = 0,
            })
            Corner(8, btn)
            Stroke(Theme.ButtonBorder, 1, btn)

            btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = Theme.ButtonHover}, 0.15) end)
            btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = Theme.ButtonBG}, 0.15) end)
            
            -- Bounce effect on click
            btn.MouseButton1Down:Connect(function() Tween(btn, {Size = UDim2.new(1, -12, 0, 34)}, 0.1) end)
            btn.MouseButton1Up:Connect(function() Tween(btn, {Size = UDim2.new(1, -4, 0, 38)}, 0.2, Enum.EasingStyle.Back) end)
            btn.MouseButton1Click:Connect(callback)
        end

        -- ── DROPDOWN ──
        function TabObj:Dropdown(text, options, callback)
            local selected = options[1]
            local open     = false

            local wrapper = New("Frame", {
                Parent               = Page,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, -4, 0, 58),
                LayoutOrder          = NextOrder(),
                ClipsDescendants     = false,
                ZIndex               = 3,
            })

            New("TextLabel", {
                Parent               = wrapper,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 2, 0, 0),
                Size                 = UDim2.new(1, 0, 0, 18),
                Text                 = text,
                TextColor3           = Theme.SubText,
                Font                 = Theme.Font,
                TextSize             = 12,
                TextXAlignment       = Enum.TextXAlignment.Left,
            })

            local header = New("TextButton", {
                Parent           = wrapper,
                BackgroundColor3 = Theme.DropdownBG,
                Position         = UDim2.new(0, 0, 0, 22),
                Size             = UDim2.new(1, 0, 0, 36),
                Text             = "",
                AutoButtonColor  = false,
                ZIndex           = 3,
                BorderSizePixel  = 0,
            })
            Corner(8, header)
            Stroke(Theme.DropdownBorder, 1, header)

            local selLabel = New("TextLabel", {
                Parent               = header,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 14, 0, 0),
                Size                 = UDim2.new(1, -34, 1, 0),
                Text                 = selected,
                TextColor3           = Theme.DropdownText,
                Font                 = Theme.FontLight,
                TextSize             = 14,
                TextXAlignment       = Enum.TextXAlignment.Left,
                ZIndex               = 4,
            })

            local arrow = New("TextLabel", {
                Parent               = header,
                BackgroundTransparency = 1,
                Position             = UDim2.new(1, -28, 0, 0),
                Size                 = UDim2.new(0, 20, 1, 0),
                Text                 = "▼",
                TextColor3           = Theme.AccentDim,
                Font                 = Theme.Font,
                TextSize             = 11,
                ZIndex               = 4,
            })

            local listFrame = New("ScrollingFrame", {
                Parent           = wrapper,
                BackgroundColor3 = Theme.DropdownOpen,
                Position         = UDim2.new(0, 0, 0, 62),
                Size             = UDim2.new(1, 0, 0, 0),
                ClipsDescendants = true,
                Visible          = false,
                ZIndex           = 10,
                ScrollBarThickness = 3,
                ScrollBarImageColor3 = Theme.AccentDim,
                BorderSizePixel = 0,
            })
            Corner(8, listFrame)
            Stroke(Theme.DropdownBorder, 1, listFrame)

            local itemList = Instance.new("UIListLayout")
            itemList.SortOrder = Enum.SortOrder.LayoutOrder
            itemList.Parent    = listFrame

            local function updateListHeight()
                local contentHeight = itemList.AbsoluteContentSize.Y
                listFrame.CanvasSize = UDim2.new(0, 0, 0, contentHeight)
                return math.clamp(contentHeight, 0, 140) -- Max dropdown height
            end

            for i, opt in ipairs(options) do
                local item = New("TextButton", {
                    Parent           = listFrame,
                    BackgroundColor3 = Theme.DropdownItem,
                    Size             = UDim2.new(1, 0, 0, 32),
                    Text             = "",
                    AutoButtonColor  = false,
                    LayoutOrder      = i,
                    ZIndex           = 11,
                    BorderSizePixel  = 0,
                })

                New("TextLabel", {
                    Parent               = item,
                    BackgroundTransparency = 1,
                    Position             = UDim2.new(0, 14, 0, 0),
                    Size                 = UDim2.new(1, -14, 1, 0),
                    Text                 = opt,
                    TextColor3           = Theme.DropdownText,
                    Font                 = Theme.FontLight,
                    TextSize             = 14,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                    ZIndex               = 12,
                })

                item.MouseEnter:Connect(function() Tween(item, {BackgroundColor3 = Theme.DropdownHover}, 0.15) end)
                item.MouseLeave:Connect(function() Tween(item, {BackgroundColor3 = Theme.DropdownItem}, 0.15) end)
                item.MouseButton1Click:Connect(function()
                    selected      = opt
                    selLabel.Text = opt
                    open          = false
                    
                    Tween(arrow, {Rotation = 0}, 0.25)
                    Tween(listFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.25)
                    Tween(wrapper, {Size = UDim2.new(1, -4, 0, 58)}, 0.25)
                    task.wait(0.25)
                    listFrame.Visible = false
                    callback(opt)
                end)
            end

            header.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    listFrame.Visible = true
                    local targetHeight = updateListHeight()
                    Tween(arrow, {Rotation = 180}, 0.25)
                    Tween(listFrame, {Size = UDim2.new(1, 0, 0, targetHeight)}, 0.25, Enum.EasingStyle.Exponential)
                    Tween(wrapper, {Size = UDim2.new(1, -4, 0, 58 + targetHeight + 4)}, 0.25, Enum.EasingStyle.Exponential)
                else
                    Tween(arrow, {Rotation = 0}, 0.25)
                    Tween(listFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.25, Enum.EasingStyle.Exponential)
                    Tween(wrapper, {Size = UDim2.new(1, -4, 0, 58)}, 0.25, Enum.EasingStyle.Exponential)
                    task.delay(0.25, function() if not open then listFrame.Visible = false end end)
                end
            end)
        end

        function WindowObj:AddConfig()
            -- Config persistence stub
        end

        return TabObj
    end

    MainFrame.Size = UDim2.new(0, 580, 0, 0)
    Tween(MainFrame, {Size = normalSize}, 0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)

    return WindowObj
end

return RBLVLibrary
