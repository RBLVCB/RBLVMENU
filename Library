    local content  = opts.Content  or ""
    local duration = opts.Duration or 4

    local card = New("Frame", {
        Name              = "Notif",
        Parent            = NotifFrame,
        BackgroundColor3  = Theme.NotifBG,
        Size              = UDim2.new(1, 0, 0, 0),
        AutomaticSize     = Enum.AutomaticSize.Y,
        ClipsDescendants  = false,
    })
    Corner(8, card)
    Stroke(Theme.NotifBorder, 1, card)

    -- Accent left bar
    New("Frame", {
        Parent           = card,
        BackgroundColor3 = Theme.Accent,
        Size             = UDim2.new(0, 3, 1, 0),
        Position         = UDim2.new(0, 0, 0, 0),
    }, {New("UICorner", {CornerRadius = UDim.new(0, 3)})})

    local inner = New("Frame", {
        Parent               = card,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 14, 0, 0),
        Size                 = UDim2.new(1, -14, 1, 0),
        AutomaticSize        = Enum.AutomaticSize.Y,
    })
    Padding(10, 10, 4, 10, inner)

    local innerList = Instance.new("UIListLayout")
    innerList.Padding   = UDim.new(0, 3)
    innerList.SortOrder = Enum.SortOrder.LayoutOrder
    innerList.Parent    = inner

    New("TextLabel", {
        Parent           = inner,
        BackgroundTransparency = 1,
        Size             = UDim2.new(1, 0, 0, 16),
        Text             = title,
        TextColor3       = Theme.NotifTitle,
        Font             = Theme.Font,
        TextSize         = 13,
        TextXAlignment   = Enum.TextXAlignment.Left,
        LayoutOrder      = 0,
    })

    New("TextLabel", {
        Parent           = inner,
        BackgroundTransparency = 1,
        Size             = UDim2.new(1, 0, 0, 0),
        AutomaticSize    = Enum.AutomaticSize.Y,
        Text             = content,
        TextColor3       = Theme.NotifText,
        Font             = Theme.FontLight,
        TextSize         = 12,
        TextWrapped      = true,
        TextXAlignment   = Enum.TextXAlignment.Left,
        LayoutOrder      = 1,
    })

    -- Slide in
    card.Position = UDim2.new(1, 320, 0, 0)
    Tween(card, {Position = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    task.delay(duration, function()
        Tween(card, {Position = UDim2.new(1, 320, 0, 0)}, 0.25)
        task.wait(0.3)
        card:Destroy()
    end)
end

