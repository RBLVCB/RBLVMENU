        -- ── TOGGLE ──
        function Tab:Toggle(text, default, callback)
            local T       = Library.CurrentTheme
            local Toggled = default or false
            Library.Flags[text] = Toggled

            local Fr = ElemBase(38)
            ElemLbl(Fr, text)

            -- Track pill — slightly smaller so the knob has 3px of padding inside
            local Track = Instance.new("Frame", Fr)
            Track.Name = "ToggleTrack"
            Track.BackgroundColor3 = Color3.fromRGB(255,255,255)
            Track.BackgroundTransparency = Toggled and 0.0 or 0.82
            Track.AnchorPoint = Vector2.new(1, 0.5)
            Track.Position = UDim2.new(1, -12, 0.5, 0)
            Track.Size = UDim2.new(0, 44, 0, 24)
            Track.BorderSizePixel = 0
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Knob = Instance.new("Frame", Track)
            Knob.Name = "ToggleKnob"
            Knob.BackgroundColor3 = Toggled and T.Accent or Color3.fromRGB(120,130,145)
            Knob:SetAttribute("On", Toggled)
            Knob.AnchorPoint = Vector2.new(0, 0.5)
            Knob.Position = Toggled and UDim2.new(1,-21,0.5,0) or UDim2.new(0,3,0.5,0)
            Knob.Size = UDim2.new(0, 18, 0, 18)
            Knob.BorderSizePixel = 0
            Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)

            local Hit = Instance.new("TextButton", Fr)
            Hit.BackgroundTransparency = 1; Hit.Size = UDim2.new(1,0,1,0)
            Hit.Text = ""; Hit.AutoButtonColor = false

            local function Update(val)
                Toggled = val; Library.Flags[text] = Toggled
                Knob:SetAttribute("On", Toggled)
                CreateTween(Track,{BackgroundTransparency = Toggled and 0.0 or 0.82},0.15)
                CreateTween(Knob, {
                    Position = Toggled and UDim2.new(1,-21,0.5,0) or UDim2.new(0,3,0.5,0),
                    BackgroundColor3 = Toggled and Library.CurrentTheme.Accent or Color3.fromRGB(120,130,145),
                }, 0.15)
                pcall(callback, Toggled)
            end
            Hit.MouseButton1Click:Connect(function() Update(not Toggled) end)
            Library.Elements[text] = {Set = function(self,v) Update(v) end}
            table.insert(Library.SearchIndex,{Name=text, Tab=name, Instance=Fr})
            return Fr
        end

        -- ── SLIDER ──
        function Tab:Slider(text, min, max, default, callback)
            local T       = Library.CurrentTheme
            local val     = default or min
            local sliding = false
            Library.Flags[text] = val

            local Fr = ElemBase(50)

            local SLbl = Instance.new("TextLabel", Fr)
            SLbl.Name = "ElemLbl"
            SLbl.BackgroundTransparency = 1
            SLbl.Position = UDim2.new(0, 12, 0, 0)
            SLbl.Size = UDim2.new(1,-56,0,24)
            SLbl.Font = Enum.Font.Gotham; SLbl.Text = text
            SLbl.TextColor3 = T.Text; SLbl.TextSize = 12
            SLbl.TextXAlignment = Enum.TextXAlignment.Left
            SLbl.TextYAlignment = Enum.TextYAlignment.Center

            local ValLbl = Instance.new("TextLabel", Fr)
            ValLbl.Name = "SliderValue"
            ValLbl.BackgroundTransparency = 1
            ValLbl.AnchorPoint = Vector2.new(1,0)
            ValLbl.Position = UDim2.new(1,-10,0,0)
            ValLbl.Size = UDim2.new(0,44,0,24)
            ValLbl.Font = Enum.Font.GothamMedium
            ValLbl.Text = tostring(val); ValLbl.TextColor3 = T.Accent
            ValLbl.TextSize = 11
            ValLbl.TextXAlignment = Enum.TextXAlignment.Right
            ValLbl.TextYAlignment = Enum.TextYAlignment.Center

            -- Track sits at y=30, taking full usable width minus symmetric 12px margins
            local Track = Instance.new("Frame", Fr)
            Track.Name = "SliderTrack"
            Track.BackgroundColor3 = Color3.fromRGB(255,255,255)
            Track.BackgroundTransparency = 0.82
            Track.BorderSizePixel = 0
            Track.Position = UDim2.new(0, 12, 0, 32)
            Track.Size     = UDim2.new(1, -24, 0, 5)
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Fill = Instance.new("Frame", Track)
            Fill.Name = "SliderFill"
            Fill.BackgroundColor3 = T.Accent; Fill.BackgroundTransparency = 0.1
            Fill.BorderSizePixel = 0
            Fill.Size = UDim2.new((val-min)/(max-min), 0, 1, 0)
            Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

            local SKnob = Instance.new("Frame", Track)
            SKnob.Name = "SliderKnob"
            SKnob.BackgroundColor3 = Color3.fromRGB(255,255,255)
            SKnob.BorderSizePixel = 0
            SKnob.AnchorPoint = Vector2.new(0.5,0.5)
            SKnob.Position = UDim2.new((val-min)/(max-min), 0, 0.5, 0)
            SKnob.Size = UDim2.new(0,10,0,10)
            Instance.new("UICorner", SKnob).CornerRadius = UDim.new(1,0)

            local Hit = Instance.new("TextButton", Fr)
            Hit.BackgroundTransparency = 1; Hit.Size = UDim2.new(1,0,1,0)
            Hit.Text = ""; Hit.AutoButtonColor = false; Hit.ZIndex = 4

            local function SetVal(v)
                val = math.clamp(v, min, max)
                Library.Flags[text] = val
                ValLbl.Text = tostring(val)
                local pct = (val-min)/(max-min)
                CreateTween(Fill,  {Size=UDim2.new(pct,0,1,0)},0.06)
                CreateTween(SKnob, {Position=UDim2.new(pct,0,0.5,0)},0.06)
                pcall(callback, val)
            end
            local function FromInput(i)
                local relX = i.Position.X - Track.AbsolutePosition.X
                SetVal(math.floor(min + (max-min)*math.clamp(relX/Track.AbsoluteSize.X,0,1)))
            end
            Hit.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    sliding=true; FromInput(i)
                end
            end)
            Hit.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    sliding=false
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                    FromInput(i)
                end
            end)
            Library.Elements[text] = {Set=function(self,v) SetVal(v) end}
            table.insert(Library.SearchIndex,{Name=text, Tab=name, Instance=Fr})
        end

        -- ── DROPDOWN ──
        function Tab:Dropdown(text, list, callback)
            local T       = Library.CurrentTheme
            local dropped = false
            local ITEM_H  = 28; local LIST_MAX = 130
            Library.Flags[text] = ""

            local Fr = Instance.new("Frame", Page)
            Fr.Name = "ElemFrame"
            Fr.BackgroundColor3 = T.Element; Fr.BackgroundTransparency = GT()
            Fr.Size = UDim2.new(1,0,0,38); Fr.ClipsDescendants = true
            Fr.BorderSizePixel = 0
            Instance.new("UICorner", Fr).CornerRadius = UDim.new(0,12)
            local FrStr = Instance.new("UIStroke", Fr)
            FrStr.Color = Color3.fromRGB(255,255,255); FrStr.Thickness = 1; FrStr.Transparency = 0.88

            local SelLbl = Instance.new("TextLabel", Fr)
            SelLbl.Name = "ElemLbl"
            SelLbl.BackgroundTransparency = 1
            SelLbl.Position = UDim2.new(0,12,0,0); SelLbl.Size = UDim2.new(1,-36,0,38)
            SelLbl.Font = Enum.Font.Gotham; SelLbl.Text = text
            SelLbl.TextColor3 = T.Text; SelLbl.TextSize = 12
            SelLbl.TextXAlignment = Enum.TextXAlignment.Left

            local Chev = Instance.new("TextLabel", Fr)
            Chev.BackgroundTransparency = 1
            Chev.AnchorPoint = Vector2.new(1,0.5)
            Chev.Position = UDim2.new(1,-14,0,19); Chev.Size = UDim2.new(0,14,0,14)
            Chev.Text = "⌄"; Chev.TextColor3 = Color3.fromRGB(120,130,145)
            Chev.Font = Enum.Font.GothamBold; Chev.TextSize = 13

            local ListFrame = Instance.new("ScrollingFrame", Fr)
            ListFrame.BackgroundColor3 = T.Top; ListFrame.BackgroundTransparency = GT()
            ListFrame.BorderSizePixel = 0
            ListFrame.Position = UDim2.new(0,0,0,40); ListFrame.Size = UDim2.new(1,0,0,LIST_MAX)
            ListFrame.CanvasSize = UDim2.new(0,0,0,0); ListFrame.ScrollBarThickness = 3
            ListFrame.ScrollBarImageColor3 = T.Accent; ListFrame.Visible = false; ListFrame.ZIndex = 5
            Instance.new("UICorner", ListFrame).CornerRadius = UDim.new(0,10)

            local IL = Instance.new("UIListLayout", ListFrame)
            IL.SortOrder = Enum.SortOrder.LayoutOrder; IL.Padding = UDim.new(0,1)
            local IP = Instance.new("UIPadding", ListFrame)
            IP.PaddingTop = UDim.new(0,3); IP.PaddingLeft = UDim.new(0,3); IP.PaddingRight = UDim.new(0,3)

            local Hit = Instance.new("TextButton", Fr)
            Hit.BackgroundTransparency = 1; Hit.Size = UDim2.new(1,0,0,38)
            Hit.Text = ""; Hit.ZIndex = 3; Hit.AutoButtonColor = false

            local function SelectItem(item)
                SelLbl.Text = text .. "  ·  " .. item
                Library.Flags[text] = item
                dropped = false; ListFrame.Visible = false
                Fr.Size = UDim2.new(1,0,0,38); Chev.Rotation = 0
                pcall(callback, item)
            end

            local function BuildItems(itemList)
                for _, c in pairs(ListFrame:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                for idx, item in ipairs(itemList) do
                    local IBtn = Instance.new("TextButton", ListFrame)
                    IBtn.BackgroundColor3 = Color3.fromRGB(255,255,255)
                    IBtn.BackgroundTransparency = 0.92
                    IBtn.Size = UDim2.new(1,0,0,ITEM_H-1)
                    IBtn.Font = Enum.Font.Gotham; IBtn.Text = item
                    IBtn.TextColor3 = Library.CurrentTheme.Text; IBtn.TextSize = 11
                    IBtn.AutoButtonColor = false; IBtn.BorderSizePixel = 0
                    IBtn.LayoutOrder = idx; IBtn.ZIndex = 6
                    Instance.new("UICorner", IBtn).CornerRadius = UDim.new(0,8)
                    IBtn.MouseButton1Click:Connect(function() SelectItem(item) end)
                    IBtn.MouseEnter:Connect(function()
                        IBtn.BackgroundColor3 = Library.CurrentTheme.Accent
                        IBtn.BackgroundTransparency = 0.5
                    end)
                    IBtn.MouseLeave:Connect(function()
                        IBtn.BackgroundColor3 = Color3.fromRGB(255,255,255)
                        IBtn.BackgroundTransparency = 0.92
                    end)
                end
                ListFrame.CanvasSize = UDim2.new(0,0,0, #itemList*ITEM_H+8)
            end
            BuildItems(list)

            local function CalcListH()
                return math.min(#list * ITEM_H + 8, LIST_MAX)
            end

            Hit.MouseButton1Click:Connect(function()
                dropped = not dropped
                if dropped then
                    local lH = CalcListH()
                    ListFrame.Size = UDim2.new(1,0,0,lH)
                    ListFrame.Visible = true; ListFrame.CanvasPosition = Vector2.new(0,0)
                    Fr.Size = UDim2.new(1,0,0, 40+lH)
                    CreateTween(Chev,{Rotation=180},0.15)
                else
                    ListFrame.Visible = false; Fr.Size = UDim2.new(1,0,0,38)
                    CreateTween(Chev,{Rotation=0},0.15)
                end
                Page.CanvasSize = UDim2.new(0,0,0, PL.AbsoluteContentSize.Y+16)
            end)

            Library.Elements[text] = {
                Set = function(self,v) SelectItem(v) end,
                Refresh = function(self, newList)
                    list = newList; BuildItems(newList)
                    if dropped then
                        local lH = CalcListH()
                        ListFrame.Size = UDim2.new(1,0,0,lH)
                        Fr.Size = UDim2.new(1,0,0,40+lH)
                        Page.CanvasSize = UDim2.new(0,0,0, PL.AbsoluteContentSize.Y+16)
                    end
                end,
            }
            table.insert(Library.SearchIndex,{Name=text, Tab=name, Instance=Fr})
            return SelLbl
        end

        -- ── TEXTBOX ──
        function Tab:Textbox(text, placeholder, callback)
            local T  = Library.CurrentTheme
            local Fr = ElemBase(52)

            local Lbl = ElemLbl(Fr, text, 6, 11)
            Lbl.Size = UDim2.new(1,-24,0,16)

            local Box = Instance.new("TextBox", Fr)
            Box.BackgroundColor3 = Color3.fromRGB(255,255,255)
            Box.BackgroundTransparency = 0.88
            Box.BorderSizePixel = 0
            Box.Position = UDim2.new(0,10,0,24); Box.Size = UDim2.new(1,-20,0,22)
            Box.Font = Enum.Font.Gotham; Box.PlaceholderText = placeholder or ""
            Box.PlaceholderColor3 = Color3.fromRGB(130,140,155)
            Box.Text = ""; Box.TextColor3 = T.Text; Box.TextSize = 11
            Box.ClearTextOnFocus = false
            Instance.new("UICorner", Box).CornerRadius = UDim.new(1,0)
            local BS = Instance.new("UIStroke", Box)
            BS.Color = T.Accent; BS.Thickness = 1; BS.Transparency = 0.72
            Box.Focused:Connect(function()  CreateTween(BS,{Transparency=0.25},0.15) end)
            Box.FocusLost:Connect(function(enter)
                CreateTween(BS,{Transparency=0.72},0.15)
                if enter then pcall(callback, Box.Text) end
            end)
            Library.Elements[text] = {Set=function(self,v) Box.Text=v end}
            table.insert(Library.SearchIndex,{Name=text, Tab=name, Instance=Fr})
        end

        -- ── KEYBIND ──
        function Tab:Keybind(text, default, callback)
            local T       = Library.CurrentTheme
            local key     = default or Enum.KeyCode.Unknown
            local binding = false
            Library.Flags[text] = key

            local Fr = ElemBase(38)
            ElemLbl(Fr, text)

            local KBtn = Instance.new("TextButton", Fr)
            KBtn.BackgroundColor3 = Color3.fromRGB(255,255,255)
            KBtn.BackgroundTransparency = 0.88
            KBtn.AnchorPoint = Vector2.new(1,0.5)
            KBtn.Position = UDim2.new(1,-12,0.5,0); KBtn.Size = UDim2.new(0,72,0,24)
            KBtn.Font = Enum.Font.GothamMedium
            KBtn.Text = key==Enum.KeyCode.Unknown and "None" or key.Name
            KBtn.TextColor3 = Color3.fromRGB(190,200,215); KBtn.TextSize = 10
            KBtn.AutoButtonColor = false; KBtn.BorderSizePixel = 0
            Instance.new("UICorner", KBtn).CornerRadius = UDim.new(1,0)
            local KBS = Instance.new("UIStroke", KBtn)
            KBS.Color = T.Accent; KBS.Thickness = 1; KBS.Transparency = 0.72

            KBtn.MouseButton1Click:Connect(function()
                binding = true; KBtn.Text = "..."; KBtn.TextColor3 = T.Accent
                CreateTween(KBS,{Transparency=0.3},0.12)
            end)
            UserInputService.InputBegan:Connect(function(input, gpe)
                if binding and not gpe and input.UserInputType==Enum.UserInputType.Keyboard then
                    key = input.KeyCode; binding = false
                    KBtn.Text = key.Name; KBtn.TextColor3 = Color3.fromRGB(190,200,215)
                    CreateTween(KBS,{Transparency=0.72},0.12)
                    Library.Flags[text] = key
                elseif not binding and not gpe and input.UserInputType==Enum.UserInputType.Keyboard then
                    if input.KeyCode == key then pcall(callback, key) end
                end
            end)
            Library.Elements[text] = {Set=function(self,k) key=k; KBtn.Text=k.Name end}
            table.insert(Library.SearchIndex,{Name=text, Tab=name, Instance=Fr})
        end

        return Tab
    end

    -- ── Built-in Config Tab ──
    function Window:AddConfig()
        local CT = Window:Tab("Config")
        CT:Label("Appearance")

        local ThemeNames = {}
        for n in pairs(Library.Themes) do table.insert(ThemeNames, n) end
        table.sort(ThemeNames)

        CT:Dropdown("Theme", ThemeNames, function(sel) Library:SetTheme(sel) end)
        CT:Toggle("Glass Transparency", true, function(val)
            Library.Settings.Transparency = val
            Library:RefreshTheme()
        end)

        CT:Label("Save / Load")
        CT:Button("Save Config", function()
            SaveConfig()
            Library:Notification({Title="Config", Content="Config saved.", Duration=3})
        end)
        CT:Button("Load Config", function()
            if LoadConfig() then
                Library:RefreshTheme()
                Library:Notification({Title="Config", Content="Config loaded.", Duration=3})
            else
                Library:Notification({Title="Config", Content="No save file found.", Duration=3})
            end
        end)
        CT:Button("Delete Config", function()
            pcall(function()
                if isfile and isfile(CONFIG_FILE) then
                    delfile(CONFIG_FILE)
                    Library:Notification({Title="Config", Content="Config deleted.", Duration=3})
                else
                    Library:Notification({Title="Config", Content="No file to delete.", Duration=3})
                end
            end)
        end)
    end

    return Window
end

return Library
