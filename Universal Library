    MainFrame.Size             = UDim2.new(0, W, 0, H)
    MainFrame.BackgroundColor3 = Library.CurrentTheme.Main
    MainFrame.BackgroundTransparency = GlassTrans()
    MainFrame.ClipsDescendants = true
    MainFrame.Visible          = not KeySystemConfig.Enabled
    if KeySystemConfig.Enabled then MainFrame.Size = UDim2.new(0, 0, 0, 0) end

    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 24)
    local MS = Instance.new("UIStroke", MainFrame)
    MS.Color     = Color3.fromRGB(255, 255, 255)
    MS.Thickness = 1.5
    MS.Transparency = 0.6

    -- Subtle inner glass highlight (top edge sheen)
    local Sheen = Instance.new("Frame", MainFrame)
    Sheen.Name             = "Sheen"
    Sheen.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Sheen.BackgroundTransparency = 0.94
    Sheen.BorderSizePixel  = 0
    Sheen.Size             = UDim2.new(1, 0, 0.4, 0)
    Sheen.ZIndex           = 0
    local SheenCorner = Instance.new("UICorner", Sheen)
    SheenCorner.CornerRadius = UDim.new(0, 24)

    -- ── Header bar ──
