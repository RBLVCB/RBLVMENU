-- Iridescent color shift effect
function Library:ApplyIridescentEffect(frame)
    pcall(function()
        local colors = {
            Color3.fromRGB(255, 0, 255),  -- Magenta
            Color3.fromRGB(0, 255, 255),  -- Cyan
            Color3.fromRGB(255, 255, 0),  -- Yellow
            Color3.fromRGB(255, 0, 255),  -- Back to Magenta
        }
        
        task.spawn(function()
            local idx = 1
            while frame and frame.Parent do
                local nextIdx = (idx % #colors) + 1
                if frame:FindFirstChildOfClass("UIStroke") then
                    local stroke = frame:FindFirstChildOfClass("UIStroke")
                    CreateTween(stroke, {Color = colors[nextIdx]}, 2)
                end
                idx = nextIdx
                task.wait(2)
            end
        end)
    end)
end

