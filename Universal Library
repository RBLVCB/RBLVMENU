end

-- Particle effect simulation for liquid glass (subtle floating dots)
function Library:AddParticleEffect(parent, color, count)
    pcall(function()
        for i = 1, (count or 3) do
            local particle = Instance.new("Frame", parent)
            particle.Name = "LiquidParticle_" .. i
            particle.BackgroundColor3 = color
            particle.BackgroundTransparency = 0.7
            particle.BorderSizePixel = 0
            particle.Size = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
            particle.Position = UDim2.new(math.random(0, 100) / 100, 0, math.random(0, 100) / 100, 0)
            Instance.new("UICorner", particle).CornerRadius = UDim.new(1, 0)
            
            -- Subtle floating animation
            local startPos = particle.Position
            local duration = math.random(3, 7)
            local offset = UDim2.new(0, math.random(-20, 20), 0, math.random(-15, 15))
            
            task.spawn(function()
                while parent and particle.Parent == parent do
                    CreateTween(particle, {Position = startPos + offset}, duration)
                    task.wait(duration)
                    CreateTween(particle, {Position = startPos}, duration)
                    task.wait(duration)
                end
            end)
        end
    end)
end

