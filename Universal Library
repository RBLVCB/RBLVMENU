-- ==================== UTILITY ====================

local function CreateTween(obj, props, t)
    local tw = TweenService:Create(obj, TweenInfo.new(t or 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
    tw:Play(); return tw
end

local function MakeDraggable(handle, frame)
    local drag, startPos, startFrame = false, nil, nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            drag = true; startPos = i.Position; startFrame = frame.Position
            i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
        end
    end)
    handle.InputChanged:Connect(function(i)
        if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local d = i.Position - startPos
            frame.Position = UDim2.new(startFrame.X.Scale, startFrame.X.Offset + d.X, startFrame.Y.Scale, startFrame.Y.Offset + d.Y)
        end
    end)
end

-- Helper: applies the current theme's glass transparency, with an
-- optional extra offset (used for elements that should look slightly
-- more/less transparent than the base frame).
local function GlassTrans(extra)
    local t = Library.CurrentTheme.Trans or 0.35
    if Library.Settings.Transparency == false then
        t = 0
    end
    t = t + (extra or 0)
    if t < 0 then t = 0 end
    if t > 0.95 then t = 0.95 end
    return t
end

-- ==================== FILE SYSTEM ====================

-- These are overridden by Library:SetProjectConfig() before CreateWindow is called.
-- Defaults are generic; each project should set its own folder and config file name.
local FOLDER_NAME = "UniversalMenu"
local CONFIG_FILE = FOLDER_NAME .. "/config.json"

function Library:SetProjectConfig(folder, configFile)
    FOLDER_NAME = folder or FOLDER_NAME
    CONFIG_FILE = (folder or FOLDER_NAME) .. "/" .. (configFile or "config.json")
end

pcall(function()
    if makefolder and not (isfolder and isfolder(FOLDER_NAME)) then
        makefolder(FOLDER_NAME)
    end
end)

Library._GetFloatData = nil
Library._SetFloatData = nil

local function SaveConfig()
    pcall(function()
        if not writefile then return end
        if makefolder and not (isfolder and isfolder(FOLDER_NAME)) then
            makefolder(FOLDER_NAME)
        end
        local data = {}
        for k, v in pairs(Library.Flags) do
            if typeof(v) == "EnumItem" then
                data[k] = tostring(v)
            else
                data[k] = v
            end
        end
        data["__theme"] = Library.Settings.Theme
        data["__transparency"] = Library.Settings.Transparency
        if Library._GetFloatData then
            data["__floats"] = Library._GetFloatData()
        end
        writefile(CONFIG_FILE, HttpService:JSONEncode(data))
    end)
end

local function LoadConfig()
    local found = false
    pcall(function()
        if not (isfile and isfile(CONFIG_FILE)) then return end
        found = true
        local data = HttpService:JSONDecode(readfile(CONFIG_FILE))
        if data["__theme"] and Library.Themes[data["__theme"]] then
            Library.CurrentTheme   = Library.Themes[data["__theme"]]
            Library.Settings.Theme = data["__theme"]
        end
        if data["__transparency"] ~= nil then
            Library.Settings.Transparency = data["__transparency"]
        end
        if data["__floats"] and Library._SetFloatData then
            Library._SetFloatData(data["__floats"])
        end
        for k, v in pairs(data) do
            if k == "__theme" or k == "__floats" or k == "__transparency" then continue end
            if Library.Elements[k] then
                pcall(function()
                    if type(v) == "string" and v:sub(1, 13) == "Enum.KeyCode." then
                        local kc = Enum.KeyCode[v:sub(14)]
                        if kc then Library.Elements[k]:Set(kc) end
                    else
                        Library.Elements[k]:Set(v)
                    end
                end)
            end
        end
    end)
    return found
end

Library.SaveConfig = SaveConfig
Library.LoadConfig = LoadConfig

