    -- ============================================================
    -- WINDOW OBJECT
    -- ============================================================
    local Window   = {}
    local FirstTab = true

    function Window:Tab(name)
        local Tab = {}

        -- Tab button
        local TabBtn = Instance.new("TextButton", TabScroll)
        TabBtn.Name = name
        TabBtn.BackgroundTransparency = 1
        TabBtn.Size = UDim2.new(0, math.max(#name*7+20, 60), 1, 0)
        TabBtn.Font = Enum.Font.GothamMedium
        TabBtn.Text = name
        TabBtn.TextColor3 = Color3.fromRGB(130,140,155)
        TabBtn.TextSize = 11
        TabBtn.BorderSizePixel = 0; TabBtn.AutoButtonColor = false

        -- Active underline bar (horizontal mode)
        local ActiveBar = Instance.new("Frame", TabBtn)
        ActiveBar.Name = "ActiveBar"
        ActiveBar.BackgroundColor3 = Library.CurrentTheme.Accent
        ActiveBar.BorderSizePixel = 0
        ActiveBar.AnchorPoint = Vector2.new(0.5, 1)
        ActiveBar.Position = UDim2.new(0.5,0,1,0)
        ActiveBar.Size = UDim2.new(0.7,0,0,2)
        ActiveBar.BackgroundTransparency = 1
        Instance.new("UICorner", ActiveBar).CornerRadius = UDim.new(1, 0)

        -- Page (scrolling content)
        local Page = Instance.new("ScrollingFrame", PagesFolder)
        Page.Name = name
        Page.BackgroundTransparency = 1
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.ScrollBarThickness = 3
        Page.ScrollBarImageColor3 = Library.CurrentTheme.Accent
        Page.Visible = false
        Page.CanvasSize = UDim2.new(0,0,0,0)
        Page.BorderSizePixel = 0

        local PL = Instance.new("UIListLayout", Page)
        PL.SortOrder = Enum.SortOrder.LayoutOrder
        PL.Padding = UDim.new(0, 5)

        -- Uniform padding so content is symmetric and never bleeds into
        -- the rounded corner of MainFrame. 12px sides/bottom is enough
        -- to clear the 16px corner at normal viewing angles.
        local PP = Instance.new("UIPadding", Page)
        PP.PaddingTop    = UDim.new(0, 8)
        PP.PaddingBottom = UDim.new(0, 12)
        PP.PaddingLeft   = UDim.new(0, 10)
        PP.PaddingRight  = UDim.new(0, 10)

        PL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Page.CanvasSize = UDim2.new(0,0,0, PL.AbsoluteContentSize.Y + 16)
        end)

        TabBtn.MouseButton1Click:Connect(function() SwitchToTab(name) end)
        TabBtn.MouseEnter:Connect(function()
            if TabBtn.TextColor3 ~= Library.CurrentTheme.Accent then
                CreateTween(TabBtn,{TextColor3=Color3.fromRGB(200,210,225)},0.12)
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if TabBtn.TextColor3 ~= Library.CurrentTheme.Accent then
                CreateTween(TabBtn,{TextColor3=Color3.fromRGB(130,140,155)},0.12)
            end
        end)

        if FirstTab then
            FirstTab = false
            TabBtn.TextColor3 = Library.CurrentTheme.Accent
            ActiveBar.BackgroundTransparency = 0
            Page.Visible = true
        end

        table.insert(_tabRegistry, {name=name, page=Page, btn=TabBtn})

        -- ── Element helpers ──

        -- Base frame for all elements — uniform height, symmetric corners
        local function ElemBase(h)
            local f = Instance.new("Frame", Page)
            f.Name = "ElemFrame"
            f.BackgroundColor3 = Library.CurrentTheme.Element
            f.BackgroundTransparency = GT()
            f.Size = UDim2.new(1, 0, 0, h or 38)
            f.BorderSizePixel = 0
            Instance.new("UICorner", f).CornerRadius = UDim.new(0, 12)
            local stroke = Instance.new("UIStroke", f)
            stroke.Color = Color3.fromRGB(255,255,255)
            stroke.Thickness = 1; stroke.Transparency = 0.88
            return f
        end

        -- Standard left-side label inside an ElemFrame
        local function ElemLbl(parent, txt, yOff, sz)
            local l = Instance.new("TextLabel", parent)
            l.Name = "ElemLbl"
            l.BackgroundTransparency = 1
            l.Position = UDim2.new(0, 12, 0, yOff or 0)
            l.Size = UDim2.new(0.72, 0, 1, 0)
