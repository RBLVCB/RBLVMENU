    function Library:RefreshTheme()
        local T = Library.CurrentTheme
        CreateTween(MainFrame, {BackgroundColor3 = T.Main, BackgroundTransparency = T.Trans}, 0.25)
        CreateTween(Header,    {BackgroundColor3 = T.Top, BackgroundTransparency = T.Trans}, 0.25)
        CreateTween(HFix,      {BackgroundColor3 = T.Top, BackgroundTransparency = T.Trans}, 0.25)
        CreateTween(TabRail,   {BackgroundColor3 = T.Top, BackgroundTransparency = T.Trans}, 0.25)
        CreateTween(TabRailFix,{BackgroundColor3 = T.Top, BackgroundTransparency = T.Trans}, 0.25)
        CreateTween(SearchBox, {BackgroundColor3 = T.Element, BackgroundTransparency = T.Trans}, 0.25)
        CreateTween(MS,        {Color = T.Accent}, 0.25)
        TitleDot.BackgroundColor3 = T.Accent
        TitleLbl.TextColor3       = T.Text
        OpenBtn.BackgroundColor3  = T.Top
        OpenBtn.BackgroundTransparency = T.Trans + 0.1
        OBS.Color                 = T.Accent

        for _, obj in pairs(TabScroll:GetChildren()) do
            if obj:IsA("TextButton") then
                if obj:FindFirstChild("ActiveBar") and obj.ActiveBar.BackgroundTransparency == 0 then
                    obj.TextColor3 = T.Accent
                    obj.ActiveBar.BackgroundColor3 = T.Accent
                else
                    obj.TextColor3 = Color3.fromRGB(130, 140, 160)
                    if obj:FindFirstChild("ActiveBar") then
                        obj.ActiveBar.BackgroundColor3 = T.Accent
                    end
                end
            end
        end

        for _, page in pairs(PagesFolder:GetChildren()) do
            if page:IsA("ScrollingFrame") then
                for _, elem in pairs(page:GetChildren()) do
                    if elem:IsA("Frame") and elem.Name == "ElemFrame" then
                        CreateTween(elem, {BackgroundColor3 = T.Element, BackgroundTransparency = T.Trans}, 0.25)
                        local lbl = elem:FindFirstChildOfClass("TextLabel")
                        if lbl then lbl.TextColor3 = T.Text end
                    elseif elem:IsA("TextLabel") and elem.Name == "SectionLbl" then
                        elem.TextColor3 = T.Accent
                        local ln = elem:FindFirstChild("Line")
                        if ln then ln.BackgroundColor3 = T.Accent end
                    end
                end
            end
        end
    end

