            local Fr = ElemBase(40)
            ElemLabel(Fr, text)

            -- Track: bigger rounded pill (glass)
            local Track = Instance.new("Frame", Fr)
            Track.BackgroundColor3 = Toggled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(255, 255, 255)
            Track.BackgroundTransparency = Toggled and 0.05 or 0.85
            Track.AnchorPoint      = Vector2.new(1, 0.5)
            Track.Position         = UDim2.new(1, -12, 0.5, 0)
            Track.Size             = UDim2.new(0, 46, 0, 26)
            Track.BorderSizePixel  = 0
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Knob = Instance.new("Frame", Track)
            Knob.BackgroundColor3 = Toggled and T.Accent or Color3.fromRGB(120, 130, 145)
            Knob.AnchorPoint      = Vector2.new(0, 0.5)
            Knob.Position         = Toggled and UDim2.new(1, -22, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
            Knob.Size             = UDim2.new(0, 20, 0, 20)
            Knob.BorderSizePixel  = 0
