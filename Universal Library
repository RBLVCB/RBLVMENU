            TabRailFix.BackgroundColor3 = T.Top
            TabRailFix.BackgroundTransparency = GT()
            TabRailFix.BorderSizePixel = 0
            TabRailFix.Size = UDim2.new(1, 0, 0.5, 0)
            TabRailFix.Position = UDim2.new(0, 0, 0, 0)

