    -- Rebuilds tab buttons in TabScroll matching the current direction mode,
    -- and reparents page ScrollingFrames into the new PagesFolder.
    -- Called by DirBtn after ApplyTabLayout().
    local function RebuildTabsAfterSwitch()
        -- Pages are already in PagesFolder (moved by ApplyTabLayout).
        -- Just rebuild the tab buttons in the new TabScroll.
        local firstVisible = nil
        for _, entry in ipairs(_tabRegistry) do
            -- Determine if this tab was active (check ActiveBar transparency < 1)
            local wasActive = entry.page and entry.page.Visible

            -- Create a new tab button for this tab in the new TabScroll
            local name = entry.name
            local TabBtn = Instance.new("TextButton", TabScroll)
            TabBtn.Name                   = name
            TabBtn.BackgroundTransparency = 1
            TabBtn.Font                   = Enum.Font.GothamMedium
            TabBtn.Text                   = name
            TabBtn.TextSize               = 11
            TabBtn.BorderSizePixel        = 0
            TabBtn.AutoButtonColor        = false

            if tabDirection == "h" then
                TabBtn.Size       = UDim2.new(0, math.max(#name * 7 + 20, 60), 1, 0)
                TabBtn.TextColor3 = Color3.fromRGB(130, 140, 155)
            else
                TabBtn.Size       = UDim2.new(1, 0, 0, 36)
                TabBtn.TextColor3 = Color3.fromRGB(130, 140, 155)
                TabBtn.TextXAlignment = Enum.TextXAlignment.Left
                TabBtn.ZIndex = 2
                -- Indent for sidebar
                local SBPad = Instance.new("UIPadding", TabBtn)
                SBPad.PaddingLeft = UDim.new(0, 14)
            end

            local ActiveBar = Instance.new("Frame", TabBtn)
            ActiveBar.Name   = "ActiveBar"
            ActiveBar.BorderSizePixel        = 0
            ActiveBar.ZIndex = 1

            if tabDirection == "h" then
                ActiveBar.BackgroundColor3       = Library.CurrentTheme.Accent
                ActiveBar.BackgroundTransparency = wasActive and 0 or 1
                ActiveBar.AnchorPoint = Vector2.new(0.5, 1)
                ActiveBar.Position    = UDim2.new(0.5, 0, 1, 0)
                ActiveBar.Size        = UDim2.new(0.7, 0, 0, 2)
                Instance.new("UICorner", ActiveBar).CornerRadius = UDim.new(1, 0)
            else
                -- Vertical mode: full pill background highlight
                ActiveBar.BackgroundColor3       = Color3.fromRGB(255, 255, 255)
                ActiveBar.BackgroundTransparency = wasActive and 0.85 or 1
                ActiveBar.AnchorPoint = Vector2.new(0, 0.5)
                ActiveBar.Position    = UDim2.new(0, 0, 0.5, 0)
                ActiveBar.Size        = UDim2.new(1, 0, 1, 0)
                Instance.new("UICorner", ActiveBar).CornerRadius = UDim.new(1, 0)
            end

            if wasActive then
                TabBtn.TextColor3 = Library.CurrentTheme.Accent
                firstVisible = name
            end

            TabBtn.MouseButton1Click:Connect(function() SwitchToTab(name) end)
            TabBtn.MouseEnter:Connect(function()
                if TabBtn.TextColor3 ~= Library.CurrentTheme.Accent then
                    CreateTween(TabBtn, {TextColor3 = Color3.fromRGB(200, 210, 225)}, 0.12)
                end
            end)
            TabBtn.MouseLeave:Connect(function()
                if TabBtn.TextColor3 ~= Library.CurrentTheme.Accent then
                    CreateTween(TabBtn, {TextColor3 = Color3.fromRGB(130, 140, 155)}, 0.12)
                end
            end)

            entry.btn = TabBtn
        end

        -- If nothing was active, activate the first tab
        if not firstVisible and #_tabRegistry > 0 then
            SwitchToTab(_tabRegistry[1].name)
        end
    end

    DirBtn.MouseButton1Click:Connect(function()
        tabDirection = (tabDirection == "h") and "v" or "h"
        DirBtn.Text = (tabDirection == "h") and "⇆" or "⇅"
        -- Rebuild layout scaffolding (destroys old TabRail & PageContainer,
        -- creates fresh ones, assigns new TabScroll & PagesFolder upvalues)
        ApplyTabLayout()
        -- Repopulate buttons and reparent pages
        RebuildTabsAfterSwitch()
    end)

    -- ── Theme Refresh ──
    function Library:RefreshTheme()
        local T = Library.CurrentTheme
        local trans = GlassTrans()
        CreateTween(MainFrame, {BackgroundColor3 = T.Main, BackgroundTransparency = trans}, 0.25)
        CreateTween(Header,    {BackgroundColor3 = T.Top, BackgroundTransparency = trans}, 0.25)
        CreateTween(HFix,      {BackgroundColor3 = T.Top, BackgroundTransparency = trans}, 0.25)
        CreateTween(TabRail,   {BackgroundColor3 = T.Top, BackgroundTransparency = trans}, 0.25)
        CreateTween(TabRailFix,{BackgroundColor3 = T.Top, BackgroundTransparency = trans}, 0.25)
        CreateTween(SearchBox, {BackgroundColor3 = T.Element, BackgroundTransparency = trans}, 0.25)
        CreateTween(MS,        {Color = T.Accent}, 0.25)
        TitleDot.BackgroundColor3 = T.Accent
        TitleLbl.TextColor3       = T.Text
        OpenBtn.BackgroundColor3  = T.Top
        OpenBtn.BackgroundTransparency = GlassTrans(0.1)
        OBS.Color                 = T.Accent
        OpenBtn.TextColor3        = T.Accent

        for _, obj in pairs(TabScroll:GetChildren()) do
            if obj:IsA("TextButton") then
                local bar = obj:FindFirstChild("ActiveBar")
                local isActive = bar and bar.BackgroundTransparency < 1
                if isActive then
                    obj.TextColor3 = T.Accent
                    if tabDirection == "h" then
                        bar.BackgroundColor3 = T.Accent
                    end
                else
                    obj.TextColor3 = Color3.fromRGB(130, 140, 155)
                end
            end
        end

        for _, page in pairs(PagesFolder:GetChildren()) do
            if page:IsA("ScrollingFrame") then
                for _, elem in pairs(page:GetChildren()) do
                    if elem:IsA("Frame") and elem.Name == "ElemFrame" then
                        CreateTween(elem, {BackgroundColor3 = T.Element, BackgroundTransparency = trans}, 0.25)
                        local lbl = elem:FindFirstChildOfClass("TextLabel")
                        if lbl then lbl.TextColor3 = T.Text end
                        local stroke = elem:FindFirstChildOfClass("UIStroke")
                        if stroke then stroke.Color = T.Accent end
                    elseif elem:IsA("TextLabel") and elem.Name == "SectionLbl" then
                        elem.TextColor3 = T.Accent
                        local ln = elem:FindFirstChild("Line")
                        if ln then ln.BackgroundColor3 = T.Accent end
                    end
                end
            end
        end
    end

