                ActivePill.BackgroundTransparency = wasActive and 0.78 or 1
                ActivePill.BorderSizePixel = 0
                ActivePill.Size = UDim2.new(1,0,1,0)
                Instance.new("UICorner", ActivePill).CornerRadius = UDim.new(0, 10)

