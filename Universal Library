            local Track = Instance.new("Frame", Fr)
            Track.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Track.BackgroundTransparency = 0.85
            Track.BorderSizePixel  = 0
            Track.Position = UDim2.new(0, 14, 0, 34)
            Track.Size     = UDim2.new(1, -28, 0, 5)
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Fill = Instance.new("Frame", Track)
            Fill.BackgroundColor3 = T.Accent
            Fill.BackgroundTransparency = 0.15
            Fill.BorderSizePixel  = 0
            Fill.Size             = UDim2.new((val - min) / (max - min), 0, 1, 0)
            Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

            local SKnob = Instance.new("Frame", Track)
            SKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            SKnob.BorderSizePixel  = 0
            SKnob.AnchorPoint      = Vector2.new(0.5, 0.5)
            SKnob.Position         = UDim2.new((val - min) / (max - min), 0, 0.5, 0)
            SKnob.Size             = UDim2.new(0, 10, 0, 10)
            Instance.new("UICorner", SKnob).CornerRadius = UDim.new(1, 0)

            -- Hit zone covers the WHOLE frame so dragging anywhere on the row works
            local HitBtn = Instance.new("TextButton", Fr)
            HitBtn.BackgroundTransparency = 1
            HitBtn.Size             = UDim2.new(1, 0, 1, 0)
            HitBtn.Text             = ""
            HitBtn.AutoButtonColor  = false
            HitBtn.ZIndex           = 4

            local function SetVal(v)
                val = math.clamp(v, min, max)
                Library.Flags[text] = val
                ValLbl.Text = tostring(val)
                local pct = (val - min) / (max - min)
                CreateTween(Fill,  {Size     = UDim2.new(pct, 0, 1, 0)}, 0.06)
                CreateTween(SKnob, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.06)
                pcall(callback, val)
            end
            -- Always compute from track position even though hit zone is the full frame
            local function UpdateFromInput(i)
                local relX = i.Position.X - Track.AbsolutePosition.X
                local pct  = math.clamp(relX / Track.AbsoluteSize.X, 0, 1)
                SetVal(math.floor(min + (max - min) * pct))
            end

            HitBtn.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    sliding = true; UpdateFromInput(i)
                end
            end)
            HitBtn.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if sliding and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                    UpdateFromInput(i)
                end
            end)

            Library.Elements[text] = {Set = function(self, v) SetVal(v) end}
            table.insert(Library.SearchIndex, {Name = text, Tab = name, Instance = Fr})
        end

        -- DROPDOWN
        function Tab:Dropdown(text, list, callback)
            local T        = Library.CurrentTheme
            local dropped  = false
            local ITEM_H   = 28
            local LIST_MAX = 130
            Library.Flags[text] = ""

            local Fr = Instance.new("Frame", Page)
            Fr.Name             = "ElemFrame"
            Fr.BackgroundColor3 = T.Element
            Fr.BackgroundTransparency = GlassTrans()
            Fr.Size             = UDim2.new(1, 0, 0, 40)
            Fr.ClipsDescendants = true
            Fr.BorderSizePixel  = 0
            Instance.new("UICorner", Fr).CornerRadius = UDim.new(0, 18)
            local FrStroke = Instance.new("UIStroke", Fr)
            FrStroke.Color = Color3.fromRGB(255, 255, 255)
            FrStroke.Thickness = 1
            FrStroke.Transparency = 0.88

            local SelLbl = Instance.new("TextLabel", Fr)
            SelLbl.BackgroundTransparency = 1
            SelLbl.Position = UDim2.new(0, 14, 0, 0)
            SelLbl.Size     = UDim2.new(1, -36, 0, 40)
            SelLbl.Font     = Enum.Font.Gotham
            SelLbl.Text     = text
            SelLbl.TextColor3 = T.Text
            SelLbl.TextSize   = 12
            SelLbl.TextXAlignment = Enum.TextXAlignment.Left

            -- Chevron
            local Chev = Instance.new("TextLabel", Fr)
            Chev.BackgroundTransparency = 1
            Chev.AnchorPoint = Vector2.new(1, 0.5)
            Chev.Position    = UDim2.new(1, -14, 0, 20)
            Chev.Size        = UDim2.new(0, 14, 0, 14)
            Chev.Text        = "⌄"
            Chev.TextColor3  = Color3.fromRGB(120, 130, 145)
            Chev.Font        = Enum.Font.GothamBold
            Chev.TextSize    = 13

            local ListFrame = Instance.new("ScrollingFrame", Fr)
            ListFrame.BackgroundColor3     = T.Top
            ListFrame.BackgroundTransparency = GlassTrans()
            ListFrame.BorderSizePixel      = 0
            ListFrame.Position             = UDim2.new(0, 0, 0, 42)
            ListFrame.Size                 = UDim2.new(1, 0, 0, LIST_MAX)
            ListFrame.CanvasSize           = UDim2.new(0, 0, 0, 0)
            ListFrame.ScrollBarThickness   = 3
            ListFrame.ScrollBarImageColor3 = T.Accent
            ListFrame.Visible              = false
            ListFrame.ZIndex               = 5
            Instance.new("UICorner", ListFrame).CornerRadius = UDim.new(0, 14)

            local IL = Instance.new("UIListLayout", ListFrame)
            IL.SortOrder = Enum.SortOrder.LayoutOrder
            IL.Padding   = UDim.new(0, 1)
            local IP = Instance.new("UIPadding", ListFrame)
            IP.PaddingTop   = UDim.new(0, 3)
            IP.PaddingLeft  = UDim.new(0, 3)
            IP.PaddingRight = UDim.new(0, 3)

            local HitBtn = Instance.new("TextButton", Fr)
            HitBtn.BackgroundTransparency = 1
            HitBtn.Size   = UDim2.new(1, 0, 0, 40)
            HitBtn.Text   = ""
            HitBtn.ZIndex = 3
            HitBtn.AutoButtonColor = false

            local function SelectItem(item)
                SelLbl.Text         = text .. "  ·  " .. item
                Library.Flags[text] = item
                dropped             = false
                ListFrame.Visible   = false
                Fr.Size             = UDim2.new(1, 0, 0, 40)
                Chev.Rotation       = 0
                pcall(callback, item)
            end

            local function BuildItems(itemList)
                for _, c in pairs(ListFrame:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                for idx, item in ipairs(itemList) do
                    local IBtn = Instance.new("TextButton", ListFrame)
                    IBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    IBtn.BackgroundTransparency = 0.92
                    IBtn.Size             = UDim2.new(1, 0, 0, ITEM_H - 1)
                    IBtn.Font             = Enum.Font.Gotham
                    IBtn.Text             = item
                    IBtn.TextColor3       = T.Text
                    IBtn.TextSize         = 11
                    IBtn.AutoButtonColor  = false
                    IBtn.BorderSizePixel  = 0
                    IBtn.LayoutOrder      = idx
                    IBtn.ZIndex           = 6
                    Instance.new("UICorner", IBtn).CornerRadius = UDim.new(0, 12)

                    IBtn.MouseButton1Click:Connect(function() SelectItem(item) end)
                    IBtn.MouseEnter:Connect(function()
                        IBtn.BackgroundColor3 = Library.CurrentTheme.Accent
                        IBtn.BackgroundTransparency = 0.6
                        IBtn.TextColor3       = Library.CurrentTheme.Text
                    end)
                    IBtn.MouseLeave:Connect(function()
                        IBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                        IBtn.BackgroundTransparency = 0.92
                        IBtn.TextColor3       = T.Text
                    end)
                end
                local total = #itemList * ITEM_H + 8
                ListFrame.CanvasSize = UDim2.new(0, 0, 0, total)
            end

            BuildItems(list)

            -- Compute the visible list height: fit content exactly, capped at LIST_MAX
            local function CalcListH()
                local contentH = #list * ITEM_H + 8  -- 8 = top/bottom padding
                return math.min(contentH, LIST_MAX)
            end

            HitBtn.MouseButton1Click:Connect(function()
                dropped = not dropped
                if dropped then
                    local listH = CalcListH()
                    ListFrame.Size             = UDim2.new(1, 0, 0, listH)
                    ListFrame.Visible          = true
                    ListFrame.CanvasPosition   = Vector2.new(0, 0)
                    Fr.Size                    = UDim2.new(1, 0, 0, 42 + listH)
                    CreateTween(Chev, {Rotation = 180}, 0.15)
                else
                    ListFrame.Visible = false
                    Fr.Size           = UDim2.new(1, 0, 0, 40)
                    CreateTween(Chev, {Rotation = 0}, 0.15)
                end
                Page.CanvasSize = UDim2.new(0, 0, 0, PL.AbsoluteContentSize.Y + 20)
            end)

            Library.Elements[text] = {
                Set = function(self, v) SelectItem(v) end,
                Refresh = function(self, newList)
                    list = newList
                    BuildItems(newList)
                    -- If open, resize to fit the new list
                    if dropped then
                        local listH = CalcListH()
                        ListFrame.Size = UDim2.new(1, 0, 0, listH)
                        Fr.Size        = UDim2.new(1, 0, 0, 42 + listH)
                        Page.CanvasSize = UDim2.new(0, 0, 0, PL.AbsoluteContentSize.Y + 20)
                    end
                end,
            }
            table.insert(Library.SearchIndex, {Name = text, Tab = name, Instance = Fr})
            return SelLbl
        end

        -- TEXTBOX
        function Tab:Textbox(text, placeholder, callback)
            local T  = Library.CurrentTheme
            local Fr = ElemBase(54)

            local Lbl = ElemLabel(Fr, text, 8, 11)
            Lbl.Size = UDim2.new(1, -28, 0, 14)

            local Box = Instance.new("TextBox", Fr)
            Box.BackgroundColor3   = Color3.fromRGB(255, 255, 255)
            Box.BackgroundTransparency = 0.9
            Box.BorderSizePixel    = 0
            Box.Position           = UDim2.new(0, 12, 0, 26)
            Box.Size               = UDim2.new(1, -24, 0, 22)
            Box.Font               = Enum.Font.Gotham
            Box.PlaceholderText    = placeholder or ""
            Box.PlaceholderColor3  = Color3.fromRGB(130, 140, 155)
            Box.Text               = ""
            Box.TextColor3         = T.Text
            Box.TextSize           = 11
            Box.ClearTextOnFocus   = false
            Instance.new("UICorner", Box).CornerRadius = UDim.new(1, 0)
            local BS = Instance.new("UIStroke", Box); BS.Color = T.Accent; BS.Thickness = 1; BS.Transparency = 0.7

            Box.Focused:Connect(function()  CreateTween(BS, {Transparency = 0.3}, 0.15) end)
            Box.FocusLost:Connect(function(enter)
                CreateTween(BS, {Transparency = 0.7}, 0.15)
                if enter then pcall(callback, Box.Text) end
            end)

            Library.Elements[text] = {Set = function(self, v) Box.Text = v end}
            table.insert(Library.SearchIndex, {Name = text, Tab = name, Instance = Fr})
        end

        -- KEYBIND
        function Tab:Keybind(text, default, callback)
            local T       = Library.CurrentTheme
            local key     = default or Enum.KeyCode.Unknown
            local binding = false
            Library.Flags[text] = key

            local Fr = ElemBase(40)
            ElemLabel(Fr, text)

            local KBtn = Instance.new("TextButton", Fr)
            KBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            KBtn.BackgroundTransparency = 0.9
            KBtn.AnchorPoint      = Vector2.new(1, 0.5)
            KBtn.Position         = UDim2.new(1, -12, 0.5, 0)
            KBtn.Size             = UDim2.new(0, 76, 0, 26)
            KBtn.Font             = Enum.Font.GothamMedium
            KBtn.Text             = key == Enum.KeyCode.Unknown and "None" or key.Name
            KBtn.TextColor3       = Color3.fromRGB(190, 200, 215)
            KBtn.TextSize         = 10
            KBtn.AutoButtonColor  = false
            KBtn.BorderSizePixel  = 0
            Instance.new("UICorner", KBtn).CornerRadius = UDim.new(1, 0)
            local KBS = Instance.new("UIStroke", KBtn); KBS.Color = T.Accent; KBS.Thickness = 1; KBS.Transparency = 0.7

            KBtn.MouseButton1Click:Connect(function()
                binding = true
                KBtn.Text      = "..."
                KBtn.TextColor3 = T.Accent
                CreateTween(KBS, {Transparency = 0.3}, 0.12)
            end)

            UserInputService.InputBegan:Connect(function(input, gpe)
                if binding and not gpe and input.UserInputType == Enum.UserInputType.Keyboard then
                    key = input.KeyCode; binding = false
                    KBtn.Text       = key.Name
                    KBtn.TextColor3 = Color3.fromRGB(190, 200, 215)
                    CreateTween(KBS, {Transparency = 0.7}, 0.12)
                    Library.Flags[text] = key
                elseif not binding and not gpe and input.UserInputType == Enum.UserInputType.Keyboard then
                    if input.KeyCode == key then pcall(callback, key) end
                end
            end)

            Library.Elements[text] = {Set = function(self, k) key = k; KBtn.Text = k.Name end}
            table.insert(Library.SearchIndex, {Name = text, Tab = name, Instance = Fr})
        end

        return Tab
    end

    -- ── Built-in Configuration Tab ──
    function Window:AddConfig()
        local CT = Window:Tab("Config")
        CT:Label("Appearance")

        local ThemeNames = {}
        for n in pairs(Library.Themes) do table.insert(ThemeNames, n) end
        table.sort(ThemeNames)

        CT:Dropdown("Theme", ThemeNames, function(sel)
            Library:SetTheme(sel)
        end)

        CT:Toggle("Glass Transparency", true, function(val)
            Library.Settings.Transparency = val
            Library:RefreshTheme()
        end)

        CT:Label("Save / Load")

        CT:Button("Save Config", function()
            SaveConfig()
            Library:Notification({Title = "Config", Content = "Config saved.", Duration = 3})
        end)

        CT:Button("Load Config", function()
            if LoadConfig() then
                Library:RefreshTheme()
                Library:Notification({Title = "Config", Content = "Config loaded.", Duration = 3})
            else
                Library:Notification({Title = "Config", Content = "No save file found.", Duration = 3})
            end
        end)

        CT:Button("Delete Config", function()
            pcall(function()
                if isfile and isfile(CONFIG_FILE) then
                    delfile(CONFIG_FILE)
                    Library:Notification({Title = "Config", Content = "Config deleted.", Duration = 3})
                else
                    Library:Notification({Title = "Config", Content = "No file to delete.", Duration = 3})
                end
            end)
        end)
    end

    return Window
end

return Library
