    Header.BackgroundColor3 = Library.CurrentTheme.Top
    Header.BackgroundTransparency = GlassTrans()
    Header.Size             = UDim2.new(1, 0, 0, HEADER_H)
    Header.BorderSizePixel  = 0
    -- Fix rounded corners bleed at bottom
