-- Liquid glass background animation (subtle ripple effect)
local function AnimateLiquidGlassBackground(frame, theme)
    pcall(function()
        local function createRipple()
            -- Create subtle pulsing effect
            local originalTransparency = frame.BackgroundTransparency
            task.wait(math.random(3, 6))
            CreateTween(frame, {BackgroundTransparency = originalTransparency - 0.05}, 0.5)
            task.wait(0.5)
            CreateTween(frame, {BackgroundTransparency = originalTransparency}, 0.5)
            createRipple()
        end
        -- Start animation in background
        task.spawn(createRipple)
    end)
end

-- Enhanced theme with liquid glass properties
