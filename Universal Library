    -- ── Theme Refresh ──
    function Library:RefreshTheme()
        local T   = Library.CurrentTheme
        local tr  = GT()

        CreateTween(MainFrame, {BackgroundColor3=T.Main, BackgroundTransparency=tr}, 0.25)
        CreateTween(Header,    {BackgroundColor3=T.Top,  BackgroundTransparency=tr}, 0.25)
        CreateTween(HFix,      {BackgroundColor3=T.Top,  BackgroundTransparency=tr}, 0.25)
        CreateTween(TabRail,   {BackgroundColor3=T.Top,  BackgroundTransparency=tr}, 0.25)
        CreateTween(TabRailFix,{BackgroundColor3=T.Top,  BackgroundTransparency=tr}, 0.25)
        CreateTween(SearchBox, {BackgroundColor3=T.Element, BackgroundTransparency=GT(0.1)}, 0.25)
        CreateTween(MS,        {Color=Color3.fromRGB(255,255,255)}, 0.25)

        TitleDot.BackgroundColor3 = T.Accent
        TitleLbl.TextColor3       = T.Text
        OpenBtn.BackgroundColor3  = T.Top
        OpenBtn.BackgroundTransparency = GT(0.1)
        OBS.Color = T.Accent
        OpenBtn.TextColor3 = T.Accent

        -- Tab buttons
        for _, obj in pairs(TabScroll:GetChildren()) do
            if obj:IsA("TextButton") then
                local bar  = obj:FindFirstChild("ActiveBar")
                local pill = obj:FindFirstChild("ActivePill")
                local isActive = (bar  and bar.BackgroundTransparency  < 1)
                              or (pill and pill.BackgroundTransparency  < 1)
                obj.TextColor3 = isActive and T.Accent or Color3.fromRGB(130,140,155)
                if bar  then bar.BackgroundColor3  = T.Accent end
            end
        end

        -- Elements inside pages
        for _, page in pairs(PagesFolder:GetChildren()) do
            if page:IsA("ScrollingFrame") then
                page.ScrollBarImageColor3 = T.Accent
                for _, elem in pairs(page:GetChildren()) do
                    -- Section label
                    if elem:IsA("TextLabel") and elem.Name == "SectionLbl" then
                        elem.TextColor3 = T.Accent
                        local ln = elem:FindFirstChild("Line")
                        if ln then ln.BackgroundColor3 = T.Accent end

                    elseif elem:IsA("Frame") and elem.Name == "ElemFrame" then
                        -- Main frame background
                        CreateTween(elem,{BackgroundColor3=T.Element, BackgroundTransparency=tr},0.25)

                        -- First TextLabel = element name label
                        for _, child in pairs(elem:GetChildren()) do
                            if child:IsA("TextLabel") and child.Name == "ElemLbl" then
                                child.TextColor3 = T.Text
                            end
                        end

                        -- Toggle knob accent (when ON)
                        local tTrack = elem:FindFirstChild("ToggleTrack")
                        if tTrack then
                            local knob = tTrack:FindFirstChild("ToggleKnob")
                            if knob then
                                local isOn = knob:GetAttribute("On")
                                knob.BackgroundColor3 = isOn and T.Accent or Color3.fromRGB(120,130,145)
                            end
                        end

                        -- Slider fill + value label accent
                        local sTrack = elem:FindFirstChild("SliderTrack")
                        if sTrack then
                            local fill = sTrack:FindFirstChild("SliderFill")
                            if fill then fill.BackgroundColor3 = T.Accent end
                        end
                        local sVal = elem:FindFirstChild("SliderValue")
                        if sVal then sVal.TextColor3 = T.Accent end

                        -- Dropdown list
                        local listFrame = elem:FindFirstChildOfClass("ScrollingFrame")
                        if listFrame then
                            listFrame.BackgroundColor3 = T.Top
                            listFrame.BackgroundTransparency = tr
                            listFrame.ScrollBarImageColor3 = T.Accent
                        end
                    end
                end
            end
        end
    end

    function Library:SetTheme(name)
        if Library.Themes[name] then
            Library.CurrentTheme   = Library.Themes[name]
            Library.Settings.Theme = name
            Library:RefreshTheme()
        end
    end

